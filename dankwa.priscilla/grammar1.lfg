              @3RD_PSG.

was   AUX * "(^ PRED) = 'be'"
              @MOOD_IND
              @PAST3PSG_BE
              (^ PARTICIPLE) =c past.

devour   V * @MOOD_IND
              @ASP_SIMP
              @PRESNON3SG
	          @(TRANS devour).
              
devours   V * @MOOD_IND
              @ASP_SIMP
              @PRES3SG
	          @(TRANS devour).

devoured    V* (^ PARTICIPLE) = past
               @(TRANS devour).

appears   V * @MOOD_IND
              @ASP_SIMP
              @PRES3SG
	          @(INTRANS appear).

sleeps    V * @MOOD_IND
              @ASP_SIMP
              @PRES3SG
	          @(INTRANS sleep).

chase     V* @MOOD_IND
             @ASP_SIMP
             @PRESNON3SG 
             @(TRANS chase).

chases   V * @MOOD_IND
             @ASP_SIMP
             @PRES3SG
	         @(TRANS chase). 

like     V* @MOOD_IND
             @ASP_SIMP
             @PRESNON3SG 
             @(TRANS like).

likes   V * @MOOD_IND
             @ASP_SIMP
             @PRES3SG
	         @(TRANS like). 

chased    V* (^ PARTICIPLE) = past
             @(TRANS chase).

eat     V*  @MOOD_IND
            @ASP_SIMP
            @PRESNON3SG 
            @(OPT-TRANS eat).

eats   V *  @MOOD_IND
            @ASP_SIMP
            @PRES3SG
	        @(OPT-TRANS eat).
            
eaten   V*  (^ PARTICIPLE) = past
            @(TRANS eat).
           
see     V*  @MOOD_IND
            @ASP_SIMP
            @PRESNON3SG 
            @(OPT-TRANS see).

seen    V* (^ PARTICIPLE) = past
           @(TRANS see).

saw     V*  @MOOD_IND
            @PAST
            @(OPT-TRANS see).

waited     V*
            @MOOD_IND
            @ASP_SIMP
            @PAST
            @(INTRANS wait).

talked     V*
            @MOOD_IND
            @ASP_SIMP
            @PAST
            @(INTRANS talk).

sat     V*
            @MOOD_IND
            @ASP_SIMP
            @PAST
            @(INTRANS sit).

argued     V*
            @MOOD_IND
            @ASP_SIMP
            @PAST
            @(OPT-TRANS argue).


slept     V* @MOOD_IND
             @PAST
             @(INTRANS sleep).

give     V*  @MOOD_IND
            @ASP_SIMP
            @PRESNON3SG 
            @(DITRANS give).


gives     V* @MOOD_IND
            @ASP_SIMP
            @PRES3SG 
            @(DITRANS give).

gave     V* @MOOD_IND
            @ASP_SIMP
            @PAST
            @(DITRANS give).

given    V*  (^ PARTICIPLE) = past
            @(DITRANS give).



the  D *  (^ DEF) = +.

a   D *  (^ DEF) = -.

by P * @(PREP by). 

to P * @(PREP to).

on P * @(PREP on). 

in P * @(PREP in). 

with P * @(PREP with).
