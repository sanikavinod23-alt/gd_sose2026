MORPH   ENGLISH   RULES (1.0)

"sample rule"

"this deals with verbs.  
The sublexcial items are the POS assigned to the various tags in morph-lex.lfg" 

   V --> V-S_BASE "verb stem, e.g. run"
 	 V-POS_BASE "suffix saying that this is a verb: +Verb"
 	 { TNS_BASE "tense suffix, e.g. +Pres" 
 	   (PERS_BASE) "person suffix, e.g. +3sg"
	 | ASP_BASE}.   "aspectual information"

  N --> N-S_BASE      "noun stem, e.g. tiger"
      N-POS_BASE    "+Noun tag"
      NUM-S_BASE.   "+Sg or +Pl tag"

ADJ --> ADJ-S_BASE      
      ADJ-POS_BASE.    
        
      
----
MORPH   ENGLISH   LEXICON (1.0)

implement  V-S XLE @(TRANS implement).

yawn  V* @MOOD_IND @ASP_SIMP @PRESNON3SG @(INTRANS yawn);
      V-S XLE @(INTRANS yawn); ETC.

steal  V-S XLE @(TRANS steal); ETC.

stole  V*  @MOOD_IND @PAST @(TRANS steal).

house  V-S XLE @(TRANS house); ETC.

build  V-S XLE @(TRANS build); ETC.
                             
hate V-S XLE @(TRANS hate); ETC.
               
"this guesses words that are unknown to your lexicon
 to be either adjectives or nouns"
 
-unknown  ADJ-S XLE (^ PRED) = '%stem';
	  N-S XLE (^ PRED) = '%stem'.

think V-S XLE (^PRED) = '%stem<(^SUBJ)(^COMP)>';
      V* @MOOD_IND @ASP_SIMP @PRESNON3SG
        { (^ PRED) = 'think<(^ SUBJ)(^ COMP)>'
         | @(OPT-TRANS think)};
      V* { (^ PRED) = 'think<(^ SUBJ)(^ COMP)>'
         | @(OPT-TRANS think)}.


say   V-S XLE { (^ PRED) ='say<(^ SUBJ)(^ COMP)>'
	       |(^ PRED) = 'say<(^ SUBJ)(^ OBJ)>'}.

convince  V-S XLE (^ PRED) = 'convince<(^ SUBJ)(^ OBJ)(^ XCOMP)>'
	      (^ OBJ) = (^ XCOMP SUBJ).

try 	  V-S XLE (^ PRED) ='try<(^ SUBJ)(^ XCOMP)>'
	      (^ SUBJ) = (^ XCOMP SUBJ).

persuade  V-S XLE (^ PRED) = 'persuade<(^ SUBJ)(^ OBJ)(^ XCOMP)>'
	      (^ OBJ) = (^ XCOMP SUBJ).

seems V-S XLE (^ PRED) = 'seems<(^ XCOMP)>'
         (^ XCOMP SUBJ) = (^ SUBJ).

rain  V-S XLE (^ PRED) = 'rain<(^ SUBJ)>'.

be  AUX * (^ PRED) = 'be'.

thought  V*  @MOOD_IND @PAST (^ PRED) = 'think<(^ SUBJ)(^ COMP)>'.

want      V-S XLE { (^ PRED) = 'want<(^ SUBJ)(^ XCOMP)>'
	       (^ SUBJ) = (^ XCOMP SUBJ)
	      |(^ PRED) = 'want<(^ SUBJ)(^ OBJ)(^ XCOMP)>'
	       (^ OBJ) = (^ XCOMP SUBJ)};
          V* @MOOD_IND @ASP_SIMP @PRESNON3SG
        { (^ PRED) = 'want<(^ SUBJ)(^ XCOMP)>'
	       (^ SUBJ) = (^ XCOMP SUBJ)
	      |(^ PRED) = 'want<(^ SUBJ)(^ OBJ)(^ XCOMP)>'
	       (^ OBJ) = (^ XCOMP SUBJ)};
          V* { (^ PRED) = 'want<(^ SUBJ)(^ XCOMP)>'
	       (^ SUBJ) = (^ XCOMP SUBJ)
	      |(^ PRED) = 'want<(^ SUBJ)(^ OBJ)(^ XCOMP)>'
	       (^ OBJ) = (^ XCOMP SUBJ)}.

promise   V-S XLE { (^ PRED) = 'promise<(^ SUBJ)(^ XCOMP)>'
	       (^ SUBJ) = (^ XCOMP SUBJ)
	      |(^ PRED) = 'promise<(^ SUBJ)(^ OBJ)(^ XCOMP)>'
	       (^ SUBJ) = (^ XCOMP SUBJ)
	      |(^ PRED) = 'promise<(^ SUBJ)(^ COMP)>'}.


          
"Noun tags"

+Noun   N-POS XLE .

+Sg     NUM-S XLE (^ NUM) = sg
                  (^ PERS) = 3.

+Pl     NUM-S XLE (^ NUM) = pl
                  (^ PERS) = 3.

"Verb tags"

+Verb	V-POS XLE .

+Pres   TNS XLE @PRES.

+3sg	PERS XLE @S-AGR.

+PastBoth TNS XLE "past tense or past particle"
		 @PAST-BOTH. 
         
+PastTense  TNS XLE @PAST.

+Past   TNS XLE (^ TENSE) = past.

+123SP	PERS XLE .

+Non3sg PERS XLE @BARE-AGR.

+Prog   ASP XLE @(PROG +).

"Verb tags"

+ADJ ADJ-POS XLE.
----