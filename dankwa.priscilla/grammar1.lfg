            @ASP_SIMP
            @PRESNON3SG 
            @(OPT-TRANS sleep).

slept     V* @MOOD_IND
             @PAST
             @(INTRANS sleep).

give     V*  @MOOD_IND
            @ASP_SIMP
            @PRESNON3SG 
            @(DITRANS give).


gives     V* @MOOD_IND
            @ASP_SIMP
            @PRES3SG 
            @(DITRANS give).

gave     V* @MOOD_IND
            @ASP_SIMP
            @PAST
            @(DITRANS give).

Gave     V* @MOOD_IND
            @ASP_SIMP
            @PAST
            @(DITRANS give).

given    V*  (^ PARTICIPLE) = past
            @(DITRANS give).

educate   V * @MOOD_IND
              @ASP_SIMP
              @PRESNON3SG
	          @(TRANS educate).

educated    V* (^ PARTICIPLE) = past
               @(TRANS educate).

put  V* { @MOOD_IND
          @ASP_SIMP
          @PRESNON3SG
          @(LOC-TRANS put)
        | @MOOD_IND
          @ASP_SIMP
          @PAST
          @(LOC-TRANS put)
        | (^ PARTICIPLE) = past
          @(LOC-TRANS put) }.


"Determiners"

The  D *  (^ DEF) = +.

the  D *  (^ DEF) = +.

a   D *  (^ DEF) = -.

by P * { (^ PRED) = 'by<(^ OBJ)>'
          (^ PTYPE) = sem
          @(OT-MARK PPadj)
       | (^ PTYPE) = nosem
         (^ PFORM) = by }.

"by P * @(PREP by)."

on P * @(PREP on). 

in P * @(PREP in). 

with P * @(PREP with).

for P * @(PREP for).

from P * @(PREP from).

"Adjectives"


small  A *  (^ PRED) = 'small'.

black  A *  (^ PRED) = 'black'.

hungry  A *  (^ PRED) = 'hungry'.

bright A *  (^ PRED) = 'bright'.

intelligent A *  (^ PRED) = 'intelligent'.

efficient A *  (^ PRED) = 'efficient'.

creative  A *  (^ PRED) = 'creative'.

lazy  A *  (^ PRED) = 'lazy'.

new   A *  (^ PRED) = 'new'.

curious  A *  (^ PRED) = 'curious'.

diligent  A *  (^ PRED) = 'diligent'.

happy     A *  (^ PRED) = 'happy'.

"Adverbs"


quickly  Adv *  (^ PRED) = 'quickly'.

very  Adv *  (^ PRED) = 'very'.


"Coordination"

and  CONJ * @(COORD-FORM %stem);
     CONJnp * @(COORD-FORM %stem) @(NUM pl).
     

"complementizers"

that C * (^COMP-FORM) = that.

to P * @(PREP to); 
PARTinf * (^ VFORM) =c inf.


"Punctuation"

,   COMMA * .

.   PERIOD * .

!   EXCLAMATION * .



"Possesive Pronouns"

my    Pron * @(PRON-POSS I sg 1).

your  Pron * @(PRON-POSS you sg 2).

his   Pron * @(PRON-POSS he sg 3).

hers   Pron * { @(PRON-OBJ she sg 3)
             | @(PRON-POSS she sg 3)}.

our   Pron * @(PRON-POSS we pl 1).

their Pron * @(PRON-POSS they pl 3).


"Subject Pronouns (1st,3rd Person Sg,Pl )"


I   PRON * @(PRON-SUBJ I sg 1).

he   PRON * @(PRON-SUBJ he sg 3).

she   PRON * @(PRON-SUBJ she sg 3).

we   PRON * @(PRON-SUBJ we pl 1).

they   PRON * @(PRON-SUBJ they pl 3).



"Object Pronouns  (1st,3rd Person Sg,Pl)"


me   PRON * @(PRON-OBJ I sg 1).

him   PRON * @(PRON-OBJ he sg 3).

her   PRON * @(PRON-OBJ she sg 3).

us   PRON * @(PRON-OBJ we pl 1).

them   PRON * @(PRON-OBJ they pl 3).



"Subject & Object Pronouns(2nd person & it)"


you  PRON * { @(PRON-SUBJ you sg 2)
         | @(PRON-SUBJ you pl 2)
         | @(PRON-OBJ you sg 2)
         | @(PRON-OBJ you pl 2) }.

it PRON * { @(PRON-SUBJ it sg 3)
       | @(PRON-OBJ it sg 3) }.


