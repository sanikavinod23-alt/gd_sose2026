            (^ NUM)  = pl
            (^ PERS) = 3
            (^ CASE) = acc.

him  PRON * (^ PRED) = 'pro'
            (^ NUM)  = sg
            (^ PERS) = 3
	    (^ GEND)=fem
            (^ CASE) = acc.

her  D * (^ POSS PRED) = 'pro'
         (^ POSS PERS) = 3
         (^ POSS NUM)  = sg
         (^ POSS GEND) = fem
         (^ DEF) = +.

