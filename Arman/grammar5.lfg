	      @PRES3PL.


was       AUX * "(^ PRED) = 'be'"
                @PST
	        @INDIC
                (^ PARTICIPLE) =c past.


sees     V * @(TRANS see)
             @PRES3SG
             @INDIC.

saw	 V * @(TRANS see)
             @PAST
	     @INDIC.

sat 	 V * @(INTRANS sit)
             @PAST
	     @INDIC.

seen     V * @(TRANS see)
             @PARTICIP
	     @PASSIV.

slept	 V * @(INTRANS sleep)
             @PAST
             @INDIC.

give	 V * @(DITRANS give)
	     @PRES3PL
	     @INDIC.

