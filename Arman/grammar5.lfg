             @PRES3SG
             @INDIC.

gave	 V * @(DITRANS give)
	     @PAST
	     @INDIC.

put	 V * @(TRANS put)
	     @PAST
	     @INDIC.

put	 V * @(TRANS put)
             @PARTICIP
             @PASSIV.

