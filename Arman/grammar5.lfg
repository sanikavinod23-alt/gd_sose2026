DEMO   ENGLISH   CONFIG (1.0)
  ROOTCAT   S.
  FILES  .
  RULES   (DEMO ENGLISH).
  TEMPLATES (DEMO ENGLISH).
    LEXENTRIES   (DEMO ENGLISH).
   
  GOVERNABLERELATIONS    SUBJ OBJ OBJ2 COMP XCOMP OBL OBL-?+.
  SEMANTICFUNCTIONS    ADJUNCT  TOPIC FOCUS POSS STANDARD.
  NONDISTRIBUTIVES    NUM PERS CONJ-FORM.
  EPSILON   e.
  OPTIMALITYORDER NOGOOD +PPattach PPadj.

----

DEMO   ENGLISH   RULES (1.0)

   S --> NP: (^ SUBJ)=!
	     (! CASE)=nom;
	 VP: ^=!;
	 (PERIOD).
     
   NP --> {  (D)
	     AP*: ! $ (^ ADJUNCT);
	     N   
             PP*: ! $ (^ ADJUNCT)
                  (! PTYPE) =c sem
		  @(OT-MARK PPattach)
	   | PRON: ^ = !
	   }.   


   AP --> Adv*: ! $ (^ ADJUNCT);
	  A
	  (COMMA).

   VP --> (AUX: ^ = !)   
          V: ^=!; 
          (NP: (^ OBJ)=!   
               (! CASE)=acc)
          (NP: (^ OBJ2)=!) 
          
	  PP*: { ! $ (^ ADJUNCT)
          	     (! PTYPE) =c sem
		     @(OT-MARK PPadj)
		     (! ANIM) =c -
                     |
          	     (^ OBL) = !
		     (! ANIM) =c +
		     |
		     (^ OBL) = !
		     (! PFORM)=c for
		     (! ANIM)=c +
          	       }; 

          (PP: (^ OBL-TO) = !
 	              (! PFORM)=c to)

          (PP: (^ OBL-AG) = !
	              (! PFORM)=c by)

	  Adv*: ! $ (^ ADJUNCT).


   PP --> { P: ^ = !
               (! PTYPE) =c sem;
           NP: (^ OBJ) = !
               (! CASE) = acc
	       (^ ANIM) = (! ANIM)
               |
           P: ^ = !
              (! PTYPE) =c nosem;
           NP: (^ OBJ) = !
	       (^ ANIM) = (! OBJ ANIM)
          }.  
  
----

DEMO ENGLISH TEMPLATES (1.0)


CN-SG(P) = (^ PRED) = 'P'
           (^ NUM)  = sg
           (^ PERS) = 3
	   (^ DEF).

CN-PL(P) = (^ PRED) = 'P'
           (^ NUM)  = pl
           (^ PERS) = 3.

PRES3SG = (^ TENSE) = pres
          (^ SUBJ PERS) =c 3
          (^ SUBJ NUM) =c sg.

PRES3PL = (^ TENSE) = pres
          (^ SUBJ PERS) =c 3 
          (^ SUBJ NUM) =c pl.

PAST = (^ TENSE) = past.		"کلا برای اقعال زمان گذشته"

PST = (^ TENSE) = past			"برای تو بی ورب مجهول تعریف شده فقط- یک بار هم با PAST امتحان کن ببین جواب میده یا نه"
      (^ SUBJ PERS) = 3
      (^ SUBJ NUM) = sg.

INTRANS(P) = (^ PRED) = 'P<(^ SUBJ)>'.

TRANS(P) = @(PASS (^ PRED)='P<(^ SUBJ)(^ OBJ)>').

DITRANS(P) =
   @(PASS
      @(DAT-SHIFT
         (^ PRED) = 'P<(^ SUBJ)(^ OBJ)(^ OBL-TO)>'
      )
   ).

OPT-TRANS(P) = { @(INTRANS P) | @(TRANS P) }.

INDIC = (^ MOOD) = indicative.

DAT-SHIFT(FRAME) =
   { FRAME
   | FRAME
     (^ OBJ) --> (^ OBJ2)
     (^ OBL-TO) --> (^ OBJ)
   }.


PASS(FRAME) =
   { FRAME
   | FRAME
     (^ SUBJ) --> (^ OBL-AG)
     (^ OBJ) --> (^ SUBJ)
     (^ PASSIVE) = +
   }.


PARTICIP = (^ PARTICIPLE) = past.

PASSIV = (^ PASSIVE) = +.

PREP(P) = { (^ PRED) = 'P<(^ OBJ)>'
	    (^ PTYPE) = sem
	    (^ PFORM) = P
	  | (^ PTYPE) = nosem
	    (^ PFORM) = P }.

ADJ(P) = (^ PRED) = 'P'.

OT-MARK(MARK) = (^ OT-MARK MARK) = +.

ANIMATE =   (^ ANIM) = +.

INANIMATE =   (^ ANIM) = -.

----

