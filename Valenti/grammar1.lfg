DEMO   ENGLISH   CONFIG (1.0)
  ROOTCAT   ROOT.
  FILES common.templates.lfg .  
  LEXENTRIES   (DEMO ENGLISH).
  TEMPLATES (DEMO ENGLISH) (STANDARD COMMON). 
  RULES   (DEMO ENGLISH).
  GOVERNABLERELATIONS    SUBJ OBJ OBJ2 COMP XCOMP OBL OBL-?+.
  SEMANTICFUNCTIONS    ADJUNCT  TOPIC FOCUS POSS STANDARD.
  NONDISTRIBUTIVES    NUM PERS CONJ-FORM.
  EPSILON   e.
  OPTIMALITYORDER NOGOOD PPadj +NonAnimOBL +AnimOBL +LocAttach.
  GENOPTIMALITYORDER GenBadPunct NOGOOD  +CAPITAL +PUNCT.

----

DEMO   ENGLISH   RULES (1.0)

   ROOT --> { S
	(PERIOD: @(OT-MARK PUNCT))
	|
	Simp
	}.

   Simp --> e: (^ SUBJ PRED) = 'pro'
	(^ SUBJ PERS) = 2;
	VP: (^ MOOD) = imperative;
	EXCL.

   S --> NP: (^ SUBJ)=!
	     (! CASE) =nom
		(! CAPITAL) = +
		@(OT-MARK CAPITAL);
 	 VP: ^=!;
	(PUNCT: (! PFORM) =c period 
	         @(OT-MARK PUNCT)).

  VP --> (AUX)  
 	  V: ^=!;   "head of VP"
 	  (NP: (^ OBJ)=! 
       (! CASE)=acc)
 	  (NP: (^ OBJ2) = !) 
 	  PP*: { ! $ (^ ADJUNCT) 
		 (! PTYPE) =c sem "only semantic PPs here"
		 {
		 @(OT-MARK LocAttach)
		 (! OBJ LOC) =c +
		 |
		 @(OT-MARK PPadj)
		 (! OBJ LOC) ~= +
                 }
		  "disprefer adjunct PPs" 
	       | (^ OBL) = ! "or a a general oblique"
	         {@(OT-MARK NonAnimOBL)
		  (! PTYPE) =c sem }
	       };
 	  (PP: (^ OBL-TO) = ! "special obl for ditransitives"
	       "example of a constraining equation: require a value with =c"
	       (! PFORM) =c to)
 	  (PP: (^ OBL-AG) = ! "oblique agent of passive"
	       { (! ANIMATE) =c +
	         @(OT-MARK AnimOBL) }
	       "example of a constraining equation: require a value with =c"
	       (! PFORM) =c by 
	       (! PASSIVE) =c + ) 
	 (ADV: ! $ (^ ADJUNCT)). 


   NP -->  { PRON: ^=! "could be a pronoun"
          | { (D: ^=!) 
            | D: (^ POSS) = !             }
            AP*: ! $ (^ ADJUNCT); 
          N: ^=!
          }
          PP*: ! $ (^ ADJUNCT)
	  (! PTYPE) =c sem. 

   PP -->  { P: ^ = !
            (! PTYPE) =c sem; "Adjunct"
         NP: (^ OBJ) = !
            (! CASE) = acc
       |
         P: ^ = !
            (! PTYPE) =c nosem; "OBL"
         NP: ^ = !
	(! PFORM)
	(! CASE) = acc
       }.

   AP --> ADV*: ! $ (^ ADJUNCT);
      A
	(COMMA).

METARULEMACRO(_CAT _BASECAT _RHS) =
	{
	_RHS

	|"if it is an NP or an N, pass to NP coordination rule"
	
	e: _CAT $c { NP N };
	@(NPCOORD _CAT)

	|"if it is any other category, pass it to the same category coordination rule"

	e: _CAT ~$ { NP N };
	@(SCCOORD _CAT)

	|"allow bracketing around any category"

	LB: @(OT-MARK GenBadPunct); "preceding quote mark" "disprefer in generation"
	
	_CAT: @PUSHUP; "this pushes the quotes to the top to avoid vacuous ambiguity"
	RB "following quote mark"}.

NPCOORD(_CAT) = "coordination of nominals"
_CAT: @IN-SET "first nominal"
@NP-CONJUNCT; "calls person resolution template"
CONJnp: @PUSHUP; "conjunction"
"PUSHUP avoids vacuous ambiguity in constructions
where coordination can apply at different levels"
_CAT: @IN-SET "second nominal"
@NP-CONJUNCT.

SCCOORD(_CAT) = "coordination of non-nominals"
  "COM{EX RULES PP: with girls and with boys}"
  "COM{EX RULES S: girls sleep and boys sleep.}"
  "no features other than a COORD-FORM are provided to the coordinated
  f-structure."

   _CAT: @IN-SET; "first constituent"
   (COMMA: @(OT-MARK GenBadPunct)) "optional comma; 
                                    disprefered in generation"
                       "COM{EX RULES S: girls sleep, and boys sleep.}"

   CONJ: @PUSHUP; "conjunction"
         "PUSHUP avoids vacuous ambiguity in constructions like:
         COM{EX RULES S: boys walk and sleep.}" 

   _CAT: @IN-SET "second constituent".

----

DEMO ENGLISH TEMPLATES (1.0)

OT-MARK(_mark) = "assigns an OT mark"
		_mark $ o::*.

NP-CONJUNCT = "provides person resolution features for
nominal coordination"
{ "if either conjunct is 1st person; the whole NP is"
"EX: the boys and me}"
(! PERS)=c 1
(^ PERS)=1
|"if a conjunct is 2nd person and the NP is not
already 1st person, make it 2nd person"
(! PERS)=c 2
{ (^ PERS)=c 1 "one conjunct was 1st person"
"EX: you and I}"
|(^ PERS)=2 } "else assign 2nd person"
"EX: you and the boys}"
|"otherwise, the NP is 3rd person"
"EX: the boys and her}"
(^ PERS)=3}.

DAT-SHIFT(FRAME) = { FRAME 
		| FRAME (^ OBJ)-->(^ OBJ2) 
		(^ OBL-TO)-->(^ OBJ)}.

PASS(FRAME) = { FRAME
	(^ PASSIVE) = - "no passive"
	| FRAME "passive"
	(^ PASSIVE) =c + 
	(^ PARTICIPLE) =c past
	(^ OBJ)-->(^ SUBJ)
	{ (^ SUBJ)-->(^ OBL-AG)
	| (^ SUBJ)--> NULL }
		}. 

PRES3SG = (^ TENSE) = pres
	  (^ SUBJ PERS) = 3
	(^ MOOD) = indicative
	  (^ SUBJ NUM) = sg.

PRES3PL =  (^ TENSE) = pres
	  { (^ SUBJ PERS) = 1 | (^ SUBJ PERS) = 2 | (^ SUBJ PERS) = 3 }
	(^ MOOD) = indicative
	  (^ SUBJ NUM) = pl.

PASTSIMPLE =  (^ TENSE) = past
	(^ MOOD) = indicative
	 { (^ SUBJ NUM) = sg |(^ SUBJ NUM) = pl } .

PAST3SG = (^ PARTICIPLE) = past
	  (^ SUBJ PERS) = 3
	  (^ SUBJ NUM) = sg.

1-pers-SG = (^ PERS) = 1
        (^ NUM)= sg.

1-pers-PL = (^ PERS) = 1
        (^ NUM)= pl.

CN-SG = (^ NUM) = sg
        (^ PERS) = 3.

CN-PL = (^ NUM) = pl
        (^ PERS) = 3.

PN =    (^ PERS) = 3
	(^ NUM) = sg
	(^ NSYN) = proper
        ~[(^ DEF)]. 

INTRANS(P) = (^ PRED)='P<(^ SUBJ)>' 
		(^ PASSIVE) = -.

TRANS(P) = @(PASS (^ PRED)='P<(^ SUBJ)(^ OBJ)>').

OPT-TRANS(P) = { @(INTRANS P) | @(TRANS P) }.

OPT-PPTRANS(P) = { @(INTRANS P) | @(PPTRANS P) }.

DITRANS(P) = @(PASS @(DAT-SHIFT (^ PRED)='P<(^ SUBJ) (^ OBJ) (^ OBL-TO)>')).

LOC-TRANS(P) = @(PASS (^ PRED)='P<(^ SUBJ)(^ OBJ)(^ OBL)>').

PPTRANS (P) = (^ PRED)='P<(^ SUBJ)(^ OBL)>'.

PREP(P) = "template for most prepositions"
	{ (^ PRED) = 'P<(^OBJ)>'
	(^ PTYPE) = sem
	| (^ PTYPE) = nosem
	(^ PFORM) = P}.

PRON-PERS(P) = (^ PRED) = '_pred'
		(^ PERS) = _pers
		(^ NUM) = _num
		(^ CASE) = _case
		(^ PRON-TYPE) = pers.

PRON-NOM = (^ CASE) = nom
           (^ PRON-TYPE) = pers.

PRON-ACC = (^ CASE) = acc
           (^ PRON-TYPE) = pers.

PRON-POSS = (^ SPEC POSS PRON-TYPE) = poss
(^ SPEC PRED) = 'pro'.

LOCATION = (^ LOC) = +.

IMP = (^ TENSE) = pres
      (^ MOOD) = imperative
      (^ SUBJ PERS) = 2.
	
