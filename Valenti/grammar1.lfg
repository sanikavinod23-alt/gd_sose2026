DEMO   ENGLISH   CONFIG (1.0)
  ROOTCAT   S.
  FILES  .
  LEXENTRIES   (DEMO ENGLISH).
  TEMPLATES (DEMO ENGLISH). 
  RULES   (DEMO ENGLISH).
  GOVERNABLERELATIONS    SUBJ OBJ OBJ2 COMP XCOMP OBL OBL-?+.
  SEMANTICFUNCTIONS    ADJUNCT  TOPIC FOCUS POSS STANDARD.
  NONDISTRIBUTIVES    NUM PERS CONJ-FORM.
  EPSILON   e.
  OPTIMALITYORDER NOGOOD AnimAdj +PPATTACH +AnimOBL.
  GENOPTIMALITYORDER NOGOOD  EarlyAgent StateAdjColorAdj +CAPITAL +PUNCT +OBL-TO.

----

DEMO   ENGLISH   MORPHOLOGY (1.0)

TOKENIZE:
P!basic-parse-tok.fst G!default-gen-tokenizer.fst

----

DEMO   ENGLISH   RULES (1.0)

   S --> NP: (^ SUBJ)=!
	     (! CASE) =nom
		(! CAPITAL) = +
		@(OT-MARK CAPITAL);
 	 VP: ^=!;
	(PUNCT: (! PFORM) =c period 
	         @(OT-MARK PUNCT)).

   VP --> (AUX)
	  V: ^=!; 
 	  (NP: (^ OBJ)=!
	       (! CASE)=acc)
	(NP: (^ OBJ2)=!)
	
	ADV*: ! $ (^ ADJUNCT);

	PP*: { ! $ (^ ADJUNCT) "PPs can be adjuncts"
	(! PTYPE) =c sem 
	(^ OBJ ANIM) =c +
	 @(OT-MARK AnimAdj)
	|
	(^ OBL) = ! "or a a general oblique"
	|
	(^ OBL-TO) = ! 
	(! PFORM) =c to
	@(OT-MARK OBL-TO)
        |
	(^ OBL-AG) = ! 
	(! PFORM) =c by
	@(OT-MARK EarlyAgent)
	(^ OBL-AG ANIM)=c +
	@(OT-MARK AnimOBL) }.


   NP --> { PRON: ^=! "could be a pronoun"
          | { (D: ^=!) 
            | D: (^ POSS) = !             }
            { AP: ! $ (^ ADJUNCT) 
            | PUNCT: (! PFORM) =c comma }* N: ^=!
          }
          PP*: ! $ (^ ADJUNCT)
	  (! PTYPE) =c sem. 

   PP --> { P: ^ = !
            (! PTYPE) =c sem; "Adjunct"
         NP: (^ OBJ) = !
            (! CASE) = acc
       |
         P: ^ = !
            (! PTYPE) =c nosem; "OBL"
         NP: ^ = !
	(! PFORM)
	(! CASE) = acc
       }.

   AP --> ADV*: ! $ (^ ADJUNCT);
      A.

----

DEMO ENGLISH TEMPLATES (1.0)

OT-MARK(_mark) = "assigns an OT mark"
		_mark $ o::*.

DAT-SHIFT(FRAME) = { FRAME 
		| FRAME (^ OBJ)-->(^ OBJ2) 
		(^ OBL-TO)-->(^ OBJ)}.

PASS(FRAME) = { FRAME
	(^ PASSIVE) = - "no passive"
	| FRAME "passive"
	(^ PASSIVE) =c + 
	(^ PARTICIPLE) =c past
	(^ OBJ)-->(^ SUBJ)
	{ (^ SUBJ)-->(^ OBL-AG)
	| (^ SUBJ)--> NULL }
		}. 

PRES3SG = (^ TENSE) = pres
	  (^ SUBJ PERS) = 3
	(^ MOOD) = indicative
	  (^ SUBJ NUM) = sg.

PRES3PL =  (^ TENSE) = pres
	  { (^ SUBJ PERS) = 1 | (^ SUBJ PERS) = 2 | (^ SUBJ PERS) = 3 }
	(^ MOOD) = indicative
	  (^ SUBJ NUM) = pl.

PASTSIMPLE =  (^ TENSE) = past
	(^ MOOD) = indicative
	 { (^ SUBJ NUM) = sg |(^ SUBJ NUM) = pl } .

PAST3SG = (^ PARTICIPLE) = past
	  (^ SUBJ PERS) = 3
	  (^ SUBJ NUM) = sg.

1-pers-SG = (^ PERS) = 1
        (^ NUM)= sg.

1-pers-PL = (^ PERS) = 1
        (^ NUM)= pl.

CN-SG = (^ NUM) = sg
        (^ PERS) = 3.

CN-PL = (^ NUM) = pl
        (^ PERS) = 3.

PN =    (^ PERS) = 3
	(^ NUM) = sg
        ~[(^ DEF)]. 

INTRANS(P) = (^ PRED)='P<(^ SUBJ)>' 
		(^ PASSIVE) = -.

TRANS(P) = @(PASS (^ PRED)='P<(^ SUBJ)(^ OBJ)>').

OPT-TRANS(P) = { @(INTRANS P) | @(TRANS P) }.

OPT-PPTRANS(P) = { @(INTRANS P) | @(PPTRANS P) }.

DITRANS(P) = @(PASS @(DAT-SHIFT (^ PRED)='P<(^ SUBJ) (^ OBJ) (^ OBL-TO)>')).

LOC-TRANS(P) = @(PASS (^ PRED)='P<(^ SUBJ)(^ OBJ)(^ OBL)>').

PPTRANS (P) = (^ PRED)='P<(^ SUBJ)(^ OBL)>'.

PREP(P) = "template for most prepositions"
	{ (^ PRED) = 'P<(^OBJ)>'
	(^ PTYPE) = sem
	| (^ PTYPE) = nosem
	(^ PFORM) = P}.

PRON-PERS(P) = (^ PRED) = '_pred'
		(^ PERS) = _pers
		(^ NUM) = _num
		(^ CASE) = _case
		(^ PRON-TYPE) = pers.

PRON-NOM = (^ CASE) = nom
           (^ PRON-TYPE) = pers.

PRON-ACC = (^ CASE) = acc
           (^ PRON-TYPE) = pers.

PRON-POSS = (^ SPEC POSS PRON-TYPE) = poss
(^ SPEC PRED) = 'pro'.
	
