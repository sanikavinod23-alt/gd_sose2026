DEMO   ENGLISH   CONFIG (1.0)
  ROOTCAT   S.
  FILES  .
  LEXENTRIES   (DEMO ENGLISH).
  TEMPLATES (DEMO ENGLISH). 
  RULES   (DEMO ENGLISH).
  GOVERNABLERELATIONS    SUBJ OBJ OBJ2 COMP XCOMP OBL OBL-?+.
  SEMANTICFUNCTIONS    ADJUNCT  TOPIC FOCUS POSS STANDARD.
  NONDISTRIBUTIVES    NUM PERS CONJ-FORM.
  EPSILON   e.
  OPTIMALITYORDER NOGOOD.

----

DEMO   ENGLISH   RULES (1.0)

   S --> NP: (^ SUBJ)=!
	     (! CASE) =nom;
 	 VP: ^=!.

   VP --> (AUX)
	  V: ^=!; 
 	  (NP: (^ OBJ)=!
	       (! CASE)=acc)
	(NP: (^ OBJ2)=!) "restricted obj of di-transitives"
	
	PP*: { ! $ (^ ADJUNCT) "PPs can be adjuncts"
	(! PTYPE) =c sem "only semantic PPs here"
	|
	(^ OBL) = ! "or a a general oblique"
		}; 
	
	(PP: (^ OBL-TO) = !)
	  (PP: (^ OBL-AG) = !).


   NP --> (D: ^=!)
 	  AP*: ! $ (^ ADJUNCT);
	  
	  N
          PP*: ! $ (^ ADJUNCT)
	  (! PTYPE) =c sem. 

   PP --> { P: ^ = !
            (! PTYPE) =c sem;
         NP: (^ OBJ) = !
            (! CASE) = acc
       |
         P: ^ = !
            (! PTYPE) =c nosem;
         NP: (^ OBJ) = !
       }.

----

DEMO ENGLISH TEMPLATES (1.0)

DAT-SHIFT(FRAME) = { FRAME 
		| FRAME (^ OBJ)-->(^ OBJ2) 
		(^ OBL-TO)-->(^ OBJ)}.

PASS(FRAME) = { FRAME
	(^ PASSIVE) = - "no passive"
	| FRAME "passive"
	(^ PASSIVE) =c + 
	(^ PARTICIPLE) =c past
	(^ OBJ)-->(^ SUBJ)
	{ (^ SUBJ)-->(^ OBL-AG)
	| (^ SUBJ)--> NULL }
		}. 

PRES3SG = (^ TENSE) = pres
	  (^ SUBJ PERS) = 3
	(^ MOOD) = indicative
	  (^ SUBJ NUM) = sg.

PRES3PL =  (^ TENSE) = pres
	  (^ SUBJ PERS) = 3
	(^ MOOD) = indicative
	  (^ SUBJ NUM) = pl.

PASTSIMPLE =  (^ TENSE) = past
	  (^ SUBJ PERS) = 3
	(^ MOOD) = indicative
	 { (^ SUBJ NUM) = sg |(^ SUBJ NUM) = pl } .

PAST3SG = (^ PARTICIPLE) = past
	  (^ SUBJ PERS) = 3
	  (^ SUBJ NUM) = sg.

CN = (^ NUM)= sg
     (^ PERS) = 3.

CNS = (^ NUM)= pl
     (^ PERS) = 3.

3SG = (^ NUM) = sg
	(^ DEF) 
	(^ PERS) = 3. 

3PL = (^ NUM) = pl
	(^ DEF)
	(^ PERS) = 3. 

INTRANS(P) = (^ PRED)='P<(^ SUBJ)>' 
		(^ PASSIVE) = -.

TRANS(P) = @(PASS (^ PRED)='P<(^ SUBJ)(^ OBJ)>').

OPT-TRANS(P) = { @(INTRANS P) | @(TRANS P) }.

OPT-PPTRANS(P) = { @(INTRANS P) | (@PPTRANS P) }.

DITRANS(P) = @(PASS @(DAT-SHIFT (^ PRED)='P<(^ SUBJ) (^ OBJ) (^ OBL-TO)>')).

PPTRANS (P) = (^ PRED)='P<(^ SUBJ)(^ OBL-TO)>'.

PREP(P) = "template for most prepositions"
	{ (^ PRED) = 'P<(^OBJ)>'
	(^ PTYPE) = sem
	| (^ PTYPE) = nosem
	(^ PFORM) = P}.

