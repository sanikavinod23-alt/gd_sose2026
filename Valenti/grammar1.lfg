DEMO ENGLISH LEXICON (1.0)

"Nouns"

Alex 	  N * (^ PRED) = 'Alex'
	      @CN.

banana   N * (^ PRED) = 'banana' 
	       @CN.

bananas	  N * (^ PRED) = 'bananas'
	      @CNS.

bench    N * (^ PRED)= 'bench' 
              @3SG.

boy       N * (^ PRED)= 'boy' 
              @3SG.

boys 	  N * (^ PRED) = 'boy'
	      @3PL.

bone 	  N * (^ PRED) = 'bone'
	      @3SG.

bones 	  N * (^ PRED) = 'bone'
	      @3PL.

book 	  N * (^ PRED) = 'book'
	      @3SG.

books 	  N * (^ PRED) = 'book'
	      @3PL.

cake 	  N * (^ PRED) = 'cake'
              @3SG.

cat 	  N * (^ PRED) = 'cat'
              @3SG.

cats      N * (^ PRED) = 'cat'
	      @3PL.

dog 	  N * (^ PRED) = 'dog'
	      @3SG.

dogs 	  N * (^ PRED) = 'dog'
	      @3PL.

gorilla	  N * (^ PRED) = 'gorilla'
	      @CN.

gorillas  N * (^ PRED) = 'gorilla'
	      @CNS.

girl      N * (^ PRED)= 'girl' 
              @3SG.

Jordan 	  N * (^ PRED) = 'Jordan'
	      @CN.

letter  N * (^ PRED) = 'letter'
	       @3SG.

monkey   N * (^ PRED) = 'monkey'
	       @3SG.

mouse     N * (^ PRED) = 'mouse'
	       @3SG.

mice 	  N * (^ PRED) = 'mouse'
              @3PL.

Sam 	  N * (^ PRED) = 'Sam'
	    @CN.

Sue     N * (^ PRED) = 'Sue'
	    @CN.

table    N * (^ PRED) = 'table' 
	       @3SG.

telescope   N * (^ PRED) = 'telescope'
	       @3SG.

treat     N * (^ PRED) = 'treat' 
	       @3SG.

treats 	  N * (^ PRED) = 'treat'
              @3PL.

waiter   N * (^ PRED) = 'waiter' 
	       @3SG.

zookeeper   N * (^ PRED) = 'zookeeper' 
	       @3SG.


"verbs"

argued  V * @(PPTRANS argue) 
	@PASTSIMPLE.

appears   V * @(INTRANS appear) 
            @PRES3SG.

chase    V * @(TRANS chase) 
           @PRES3PL.

chases    V * @(TRANS chase) 
            @PRES3SG.

chased    V * (^ PARTICIPLE)=past 
             @(TRANS chase).

devours   V * @(TRANS devour) 
	    @PRES3SG.

devour   V * @(TRANS devour)
		@PRES3PL.

devoured  V * (^ PARTICIPLE)=past
	     @(TRANS devour).

eat   V * @(OPT-TRANS eat)
         @PRES3PL.

eats   V * @(OPT-TRANS eat)
            @PRES3SG.

eaten	V * (^ PARTICIPLE)=past
	 @(TRANS eat).

give     V * @(DITRANS give)
	  @PRES3PL.

gives    V * @(DITRANS give)
		@PRES3SG.

gave  	V * @(DITRANS give)
	@PASTSIMPLE.

given  V * (^ PARTICIPLE)=past
	 @(DITRANS give).

sat     V * @(PPTRANS sit) 
	@PASTSIMPLE.

sleeps   V * @(INTRANS sleep) 
            @PRES3SG.

slept    V * (^ PARTICIPLE)=past 
        @(INTRANS sleep).

see    V * @(TRANS see) 
           @PRES3PL.

sees    V * @(TRANS see) 
            @PRES3SG.

saw     V * @(TRANS see) 
	@PASTSIMPLE.

seen	V * (^ PARTICIPLE)=past
	  @(TRANS see).

sent   V * @(DITRANS send)
	@PASTSIMPLE.

talk   V * @(OPT-PPTRANS talk) 
	@PRES3PL.

talks   V * @(OPT-PPTRANS talk) 
            @PRES3SG.

talked  V * @(OPT-PPTRANS talk)
	@PASTSIMPLE.

waited  V * @(PPTRANS wait) 
	@PASTSIMPLE.


"aux"

was  AUX * (^ PASSIVE) = +
	@PAST3SG.

"det"

the  D *  (^ DEF) = +.

The  D *  (^ DEF) = +.

A   D *  (^ DEF) = -.

a   D *  (^ DEF) = -.

"prep"

by P * @(PREP by).

to P * @(PREP to).

on P * @(PREP on).

in P * @(PREP in).

with P * @(PREP with).

