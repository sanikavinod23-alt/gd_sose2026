"verbs"

argued  V * @(PPTRANS argue)
	(^ OBL PFORM)=c with
	@PASTSIMPLE.

appears   V * @(INTRANS appear) 
            @PRES3SG.

chase    V * @(TRANS chase) 
           @PRES3PL.

chases    V * @(TRANS chase) 
            @PRES3SG.

chased    V * (^ PARTICIPLE)=past 
             @(TRANS chase).

devours   V * @(TRANS devour) 
	    @PRES3SG.

devour   V * @(TRANS devour)
		@PRES3PL.

devoured  V * (^ PARTICIPLE)=past
	     @(TRANS devour).

eat   V * @(OPT-TRANS eat)
         @PRES3PL.

ate	V * @PASTSIMPLE
	     @(OPT-TRANS eat).

eats   V * @(OPT-TRANS eat)
            @PRES3SG.

eaten	V * (^ PARTICIPLE)=past
	 @(OPT-TRANS eat).

give     V * @(DITRANS give)
	  @PRES3PL.

gives    V * @(DITRANS give)
		@PRES3SG.

gave  	V * @(DITRANS give)
	@PASTSIMPLE.

given  V * (^ PARTICIPLE)=past
	 @(DITRANS give).

sat     V * @(PPTRANS sit) 
	@PASTSIMPLE.

sleeps   V * @(INTRANS sleep) 
            @PRES3SG.

slept    V * (^ PARTICIPLE)=past 
        @(INTRANS sleep).

see    V * @(TRANS see) 
           @PRES3PL.

sees    V * @(TRANS see) 
            @PRES3SG.

saw     V * @(TRANS see) 
	@PASTSIMPLE.

seen	V * (^ PARTICIPLE)=past
	  @(TRANS see).

sent   V * @(DITRANS send)
	(^ OBL PFORM) =c to
	@PASTSIMPLE.

put     V * @(LOC-TRANS put)
	(^ OBL PFORM) =c in
	@PRES3SG.

talk   V * @(OPT-PPTRANS talk) 
	@PRES3PL.

talks   V * @(OPT-PPTRANS talk) 
            @PRES3SG.

talked  V * @(PPTRANS talk)
         (^ OBL PFORM)=c to
	@PASTSIMPLE.

waited V *
	{
   		@(OPT-PPTRANS wait)
   	{
      		(^ OBL PFORM)=c on
   	|
      		(^ OBL PFORM)=c for
   	|
      		(^ OBL PFORM)=c by
   		}
	|
   		(^ PRED)='wait<(^ SUBJ)(^ OBL-AG)>'
   		(^ OBL-AG PFORM)=c by
	}
		@PASTSIMPLE.


"Adjectives"

small    A * (^ PRED) = 'small'
	(^ ADJTYPE) = size.

black    A * (^ PRED) = 'black'
	(^ ADJTYPE) = color
	@(OT-MARK ColorAdj).

hungry   A * (^ PRED) = 'hungry'
	(^ ADJTYPE) = state
	@(OT-MARK StateAdj).

"Adverbs"

quickly  ADV * (^ PRED) = 'quickly'.

very     ADV * (^ PRED) = 'very'.

"Pronouns & Possessives"

I      PRON * (^ PRED) = 'I'
		(^ PERS) = 1
              (^ NUM) = sg
		@PRON-NOM.

he     PRON * (^ PRED) = 'he'
               @CN-SG 
               @PRON-NOM.

He     PRON * (^ PRED) = 'he'
               @CN-SG 
               @PRON-NOM
	(^ CAPITAL) = +.

she    PRON * (^ PRED) = 'she'
               @CN-SG 
               @PRON-NOM.

She    PRON * (^ PRED) = 'she'
               @CN-SG 
               @PRON-NOM
	(^ CAPITAL) = +.

they   PRON * (^ PRED) = 'they'
               @CN-PL 
               @PRON-NOM.

They   PRON * (^ PRED) = 'they'
               @CN-PL 
               @PRON-NOM
	(^ CAPITAL) = +.

him    PRON * (^ PRED) = 'he'
               @CN-SG
		(^ ANIM) = +
               @PRON-ACC.

it     PRON * (^ PRED) = 'it'
               @CN-SG
               { @PRON-NOM | @PRON-ACC }.

It     PRON * (^ PRED) = 'it'
               @CN-SG
               { @PRON-NOM | @PRON-ACC }
		(^ CAPITAL) = +.

them   PRON * (^ PRED) = 'they'
               @CN-PL
               @PRON-ACC.

us     PRON * (^ PRED) = 'we'
               @1-pers-PL
               @PRON-ACC.

my     D    * (^ SPEC POSS PRED) = 'I'
               (^ SPEC POSS PERS) = 1
               (^ SPEC POSS NUM) = sg
               @PRON-POSS.

My     D    * (^ SPEC POSS PRED) = 'I'
               (^ SPEC POSS PERS) = 1
               (^ SPEC POSS NUM) = sg
               @PRON-POSS
		(^ CAPITAL) = +.

her    D    *  (^ SPEC POSS PRED) = 'she'
                   (^ SPEC POSS PERS) = 3
                   (^ SPEC POSS NUM) = sg
                   @PRON-POSS.

Her    D    *  (^ SPEC POSS PRED) = 'she'
                   (^ SPEC POSS PERS) = 3
                   (^ SPEC POSS NUM) = sg
                   @PRON-POSS
		(^ CAPITAL) = +.




       

"aux"

was  AUX * (^ PASSIVE) = +
	@PAST3SG.

"det"

the  D *  (^ DEF) = +.

The  D *  (^ DEF) = +
	(^ CAPITAL) = +.

A   D *  (^ DEF) = -
	(^ NUM) = sg
	(^ CAPITAL) = +.

a   D *  (^ DEF) = -
	 (^ NUM) = sg.

"punctuation"

.        PUNCT * (^ PFORM) = period.

,        PUNCT * (^ PFORM) = comma.

"prep"

by P * @(PREP by).

to P * @(PREP to).

on P * @(PREP on).

in P * @(PREP in).

with P * @(PREP with).

for P * { (^ PRED) = 'for<(^OBJ)>'
          (^ PTYPE) = sem
        |
          (^ PTYPE) = nosem
          (^ PFORM) = for }.

