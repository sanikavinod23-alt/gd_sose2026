DEMO ENGLISH TEMPLATES (1.0)

OT-MARK(_mark) = "assigns an OT mark, from common templates"
       _mark $ o::*.

"Passive lexical rule - maps OBJ to SUBJ, SUBJ to OBL-AG or NULL"
PASS(FRAME) =  { FRAME
                 (^ PASSIVE) = - "no passive"
             | FRAME "passive"
              (^ PASSIVE) = +
              (^ PARTICIPLE) =c past
              (^ OBJ)-->(^ SUBJ)
              { (^ SUBJ)-->(^ OBL-AG)
              | (^ SUBJ)--> NULL
              }
            }.
              

"Dative shift lexical rule - maps OBJ to OBJ2, OBL-TO to OBJ"
DAT-SHIFT(FRAME) = { FRAME
                   | FRAME
                     (^ OBJ)-->(^ OBJ2)
                     (^ OBL-TO)-->(^ OBJ)
                   }.

"Subcategorization templates"

DITRANS(P) = @(PASS @(DAT-SHIFT (^ PRED)='P<(^ SUBJ) (^ OBJ) (^ OBL-TO)>')).

DITRANS-OBL(P) = @(PASS (^ PRED)='P<(^ SUBJ) (^ OBJ) (^ OBL)>').

"transitives can passivize"
TRANS(P) = @(PASS (^ PRED)='P<(^ SUBJ) (^ OBJ)>').

INTRANS(P) = (^ PRED) = 'P<(^SUBJ)>'.

INTRANS-OBL(P) = (^ PRED) = 'P<(^SUBJ)(^OBL)>'.
             
OPT-TRANS(P) = { @(TRANS P)
	       | @(INTRANS P) }.

PRED(P) = (^ PRED) = 'P'.


"verb agreement templates"

PRES3SG = @PRES
	  @S-AGR.

PRES = (^ TNS-ASP TENSE) = pres.

PAST = (^ TNS-ASP TENSE) = past.

PASTP = (^ PARTICIPLE) = past.

PAST-BOTH = {@PAST | @PASTP}. 

BARE-AGR = { (^ SUBJ NUM) = pl
	  | (^ SUBJ PERS) ~= 3
	    (^ SUBJ NUM) = sg
	    @(OT-MARK sg-imp)
	  }.

S-AGR = (^ SUBJ PERS) = 3
	(^ SUBJ NUM) = sg. 

"DEF: existential constraint requiring SPEC to be present on the NP"

DEF = (^ SPEC).

CASE(A) = (^ CASE) = A.

ANIMATE = (^ ANIMATE) = +.

INANIMATE = (^ ANIMATE) = -.

LOCATION = (^ LOC) = +.


"Noun templates"
"CN: count nouns sg n pl - require a determiner via existential constraint"
CN(P N) = @(PRED P) 
          (^ NUM) = N
          (^ PERS) = 3
          (^ NTYPE) = count.

"Proper names - no determiner required"
NODET(P) = (^ PRED) = 'P'
           (^ NUM) = sg
           (^ PERS)= 3.

"Pronoun templates"

PRON(P Z N T) = @(PRED P)
	        (^ NUM) = N
	        (^ PERS) = Z
	        (^ PRON-TYPE) = T
	        (^ NTYPE) = pron.

"Preposition template - can be semantic or non-semantic"
PREP(P) = { (^ PRED) = 'P<(^OBJ)>'
                (^ PTYPE) = sem
              | (^ PFORM) = P
                (^ PTYPE) = nosem
              }.

"Adjective and adverb templates"

ADJ(P) = (^ PRED) = 'P'.

ADV(P) = (^ PRED) = 'P'.

