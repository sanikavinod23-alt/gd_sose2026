DEMO   ENGLISH   RULES (1.0)

   S --> NP: (^ SUBJ)=!
	     (! CASE)=nom;
 	 VP: ^=!.

   "VP rule: PP* only for adjuncts, specific positions for obliques"
   
    VP --> (AUX)
      V: ^=!;
      (NP: (^ OBJ2)=!
           (! CASE)=acc)
      (NP: (^ OBJ)=!
           (! CASE)=acc)
      PP*: ! $ (^ ADJUNCT)
           (! PTYPE) =c sem;
      (PP: (^ OBL-TO)=!
           (! PTYPE)=c nosem)
      (PP: (^ OBL-AG)=!
           (! PTYPE)=c nosem)
      (PP: (^ OBL)=!
           (! PTYPE)=c nosem).


   "NP rule with optional determiner, adjectives, head noun, and PP adjuncts"
   NP --> (D)
 	  N
          PP*: ! $ (^ ADJUNCT)
               (! PTYPE) =c sem.
   
   "PP rule distinguishing semantic from non-semantic prepositions"
   PP --> { P: ^ = !
             (! PTYPE) =c nosem;
              NP
            | P: ^ = !
              (! PTYPE) =c sem;
              NP: (^ OBJ) = !
                  (! CASE) = acc
           }.

