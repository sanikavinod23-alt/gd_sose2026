DEMO   ENGLISH   RULES (1.0) 

   S --> NP: (^ SUBJ)=!
	     (! CASE)=nom;
 	 VP: ^=!
             (^ TNS-ASP TENSE); 
 	     (PERIOD: @(OT-MARK Punct)).

   "VP rule: PP* only for adjuncts, specific positions for obliques"
   
    VP --> (AUX: ^=!)
          V: ^=!;
         (NP: (^ OBJ2) = !)
         (NP: (^ OBJ)=!
              (! CASE)=acc)
         PP*: { ! $ (^ ADJUNCT)
             (! PTYPE)=c sem
             {
               @(OT-MARK LocAttach)
               (! OBJ LOC)=c +
             |
               @(OT-MARK PPadj)
               (! OBJ LOC) ~= +
             }
           | (^ OBL)=!
             { @(OT-MARK NonAnimObl)
               (! PTYPE)=c sem }
           };
      (PP: (^ OBL-TO)=!
           (! PFORM)=c to)
      (PP: (^ OBL-AG)=!
           { (! OBJ ANIMATE)=c +
             @(OT-MARK AnimObl) }
           (! PFORM)=c by )
      ADV*: ! $ (^ ADJUNCT).


   "NP rule with pronouns, optional determiner, adjectives, head noun, and PP adjuncts"
   NP --> 
           { ({D | PRON: (^ SPEC POSS) = !
	                (^ SPEC POSS PRON-TYPE) =c poss}) 
 	    AP*: ! $ (^ ADJUNCT); 
 	    N "head of NP"
 	    PP*: ! $ (^ ADJUNCT) 
		 (! PTYPE) =c sem 
 	  | PRON: (^ PRON-TYPE) =c pers}.

  AP --> ADV*: ! $ (^ ADJUNCT);
 	  A
 	  (COMMA).
   
   "PP rule distinguishing semantic from non-semantic prepositions"
   PP --> { P: ^ = !
             (! PTYPE) =c sem;
           NP: (^ OBJ) = !
               (! CASE) = acc
            | P: ^ = !
              (! PTYPE) =c nosem;
              NP
           }.

