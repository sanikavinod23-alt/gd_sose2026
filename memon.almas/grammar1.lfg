DEMO ENGLISH TEMPLATES (1.0)

"Passive lexical rule - maps OBJ to SUBJ, SUBJ to OBL-AG or NULL"
PASSIVE(FRAME) = FRAME
              (^ PASSIVE) = +
              (^ PARTICIPLE) =c past
              (^ OBJ)-->(^ SUBJ)
              { (^ SUBJ)-->(^ OBL-AG)
              | (^ SUBJ)--> NULL
              }.
              

"Dative shift lexical rule - maps OBJ to OBJ2, OBL-TO to OBJ"
DAT-SHIFT(FRAME) = { FRAME
                   | FRAME
                     (^ OBJ)-->(^ OBJ2)
                     (^ OBL-TO)-->(^ OBJ)
                   }.

"Subcategorization templates (Active)"
INTRANS(P) = (^ PRED)='P<(^ SUBJ)>'
             (^ PASSIVE) = -.

TRANS(P) =  (^ PRED)='P<(^ SUBJ)(^ OBJ)>'
                  (^ PASSIVE)= -.

OPT-TRANS(P) = { @(INTRANS P) | @(TRANS P) }.

"Active ditransitives: allow either PP dative or double-object"
DITRANS(P) = { (^ PRED)='P<(^ SUBJ)(^ OBJ)(^ OBL-TO)>'
               (^ PASSIVE) = -
             | (^ PRED)='P<(^ SUBJ)(^ OBJ2)(^ OBJ)>'
               (^ PASSIVE) = -
             }.


"Passive versions used by participles (separate, deterministic)"
TRANS-PASS(P) = @(PASSIVE (^ PRED)='P<(^ SUBJ)(^ OBJ)>').

"Passive ditransitive:
 apply optional dative shift first, then make it passive"
DITRANS-PASS(P) =
  @(PASSIVE @(DAT-SHIFT (^ PRED)='P<(^ SUBJ)(^ OBJ)(^ OBL-TO)>')).

"Oblique-taking verbs (intransitive with oblique)"
OBLIQUE(P OFORM) = (^ PRED)='P<(^ SUBJ)(^ OBL)>'
                   (^ OBL PFORM) =c OFORM
                   (^ PASSIVE) = -.

"Tense-Aspect-Mood templates"
PRES3SG = (^ TENSE) = pres
          (^ MOOD) = indicative
          (^ SUBJ PERS) = 3
          (^ SUBJ NUM) = sg.

"Plural/base verbs"
PRES3PL = (^ TENSE) = pres
          (^ MOOD) = indicative
          (^ SUBJ PERS) = 3
          (^ SUBJ NUM) = pl.

PAST = (^ TENSE) = past
       (^ MOOD) = indicative
       (^ SUBJ PERS) = 3
       { (^ SUBJ NUM) = sg | (^ SUBJ NUM) = pl }. 

PASTPART = (^ PARTICIPLE) = past.

"Noun templates"
"CN: singular count noun - requires a determiner via existential constraint"
CN(P) = (^ PRED) = 'P'
        (^ NUM) = sg
        (^ PERS) = 3
        (^ DEF).

"Proper names - no determiner required"
NODET(P) = (^ PRED) = 'P'
           (^ NUM) = sg
           (^ PERS)= 3.

"PLN: plural noun - no determiner required"
PLN(P) = (^ PRED) = 'P'
         (^ NUM) = pl
         (^ PERS) = 3.

"Preposition template - for obliques only non-semantic"
PREP(P) = (^ PFORM) = P
          (^ PTYPE) = nosem.

"Preposition template - can be semantic or non-semantic"
PREP-SEM(P) = { (^ PRED) = 'P<(^OBJ)>'
                (^ PTYPE) = sem
              | (^ PFORM) = P
                (^ PTYPE) = nosem
              }.

