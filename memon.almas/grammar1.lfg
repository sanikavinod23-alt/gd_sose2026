DEMO ENGLISH LEXICON (1.0)

"Singular Count nouns - require a determiner"

bone      N * @(CN bone).

dog       N * @(CN dog).

cat       N * @(CN cat).

sheep     N * @(CN sheep).

mouse     N * @(CN mouse).

banana    N * @(CN banana).

treat     N * @(CN treat).

cake      N * @(CN cake).

girl      N * @(CN girl).

gorilla   N * @(CN gorilla).

meadow    N * @(CN meadow).

park      N * @(CN park).

book      N * @(CN book).

table     N * @(CN table).

bench     N * @(CN bench).

telescope N * @(CN telescope).

monkey    N * @(CN monkey).

"Proper names - no determiner"

jordan    N * @(NODET jordan).

sam       N * @(NODET sam).

alex      N * @(NODET alex).


"Plural count nouns - no determiner required"

bones     N * @(PLN bone).

dogs      N * @(PLN dog).

cats      N * @(PLN cat).

bananas   N * @(PLN banana).

gorillas  N * @(PLN gorilla).


"Verbs - 3rd person singular present"

devours   V * @(TRANS devour)
              @PRES3SG.

chases    V * @(TRANS chase)
              @PRES3SG.

eats      V * @(OPT-TRANS eat)
              @PRES3SG.

sleeps    V * @(INTRANS sleep)
              @PRES3SG.

appears   V * @(INTRANS appear)
              @PRES3SG.

sees      V * @(TRANS see)
              @PRES3SG.

gives     V * @(DITRANS give)
              @PRES3SG.

waits     V * @(OBLIQUE wait on)
              @PRES3SG.

talks     V * @(OBLIQUE talk to)
              @PRES3SG.

argues    V * @(OBLIQUE argue with)
              @PRES3SG.

sat       V * @(INTRANS sit)
              @PAST.

"Verbs - plural present / base form"

devour    V * @(TRANS devour)
              @PRES3PL.

chase     V * @(TRANS chase)
              @PRES3PL.

eat       V * @(OPT-TRANS eat)
              @PRES3PL.

sleep     V * @(INTRANS sleep)
              @PRES3PL.

appear    V * @(INTRANS appear)
              @PRES3PL.

see       V * @(TRANS see)
              @PRES3PL.

give      V * @(DITRANS give)
              @PRES3PL.

wait      V * @(OBLIQUE wait on)
              @PRES3PL.

talk      V * @(OBLIQUE talk to)
              @PRES3PL.

argue     V * @(OBLIQUE argue with)
              @PRES3PL.

"Past Participles - for passive constructions"
devoured  V * @(TRANS-PASS devour)
              @PASTPART.

chased    V * @(TRANS-PASS chase)
              @PASTPART.

eaten     V * @(TRANS-PASS eat)
              @PASTPART.

seen      V * @(TRANS-PASS see)
              @PASTPART.

slept     V * @(INTRANS sleep)
              @PASTPART.

given     V * @(DITRANS-PASS give)
              @PASTPART.

"Verb past form"

gave      V * @(DITRANS give)
              @PAST. 

saw       V * @(TRANS see)
              @PAST.

waited   V * @(OBLIQUE wait on)
             @PAST.

talked   V * @(OBLIQUE talk to)
             @PAST.

argued   V * @(OBLIQUE argue with)
             @PAST.

"Determiners"
the       D * (^ DEF) = +.

a         D * (^ DEF) = -.

"Auxiliary"
was       AUX * (^ TENSE) = past
               (^ MOOD) = indicative
               (^PASSIVE) =c +
               (^ SUBJ NUM) = sg.

were      AUX * (^ TENSE) = past
               (^ MOOD) = indicative
               (^PASSIVE) =c +
               (^ SUBJ NUM) = pl.

"Prepositions"
"by and to are non-semantic (oblique markers)"
by        P * @(PREP by).

to        P * @(PREP to).

"on, in, with can be semantic adjuncts or non-semantic obliques"
on        P * @(PREP-SEM on).

in        P * @(PREP-SEM in).

with      P * @(PREP-SEM with).

"Additional nouns for examples"
waiter    N * @(CN waiter).

zookeeper N * @(CN zookeeper).

