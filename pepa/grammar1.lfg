"VERBS"


devours   V * 
	       @MOOD-IND
            @ASPECT-SIMP
            @PRES3SG
	       @(TRANS devour).

devour     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PRES-NON3SG
            @(TRANS devour).

appears   V * 
	       @MOOD-IND
            @ASPECT-SIMP
            @PRES3SG
	       @(INTRANS appear).

wait     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PRES-NON3SG
            @(INTRANS wait).

waits    V *
	       @MOOD-IND
            @ASPECT-SIMP
            @PRES3SG
	       @(INTRANS wait).

sleep     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PRES-NON3SG
            @(INTRANS sleep).

sleeps    V *
	       @MOOD-IND
            @ASPECT-SIMP
            @PRES3SG
	       @(INTRANS sleep).

chase     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PRES-NON3SG
            @(TRANS chase).

chases   V * 
	       @MOOD-IND
            @ASPECT-SIMP
            @PRES3SG
	       @(TRANS chase).

eat     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PRES-NON3SG
            @(OPT-TRANS eat).

eats   V * 
	     @MOOD-IND
          @ASPECT-SIMP
          @PRES3SG
	     @(OPT-TRANS eat).

see     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PRES-NON3SG
            @(OPT-TRANS see).

give     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PRES-NON3SG
            @(DITRANS give).

gives   V * 
	       @MOOD-IND
            @ASPECT-SIMP
            @PRES3SG
	       @(DITRANS give).

was   AUX * "(^ PRED) = 'be'"
            @MOOD-IND
            @PAST-BE-3SG
            (^ PARTICIPLE) =c past.

seen    V* (^ PARTICIPLE) = past
           @(TRANS see).

eaten    V* (^ PARTICIPLE) = past
           @(TRANS eat).

chased    V* (^ PARTICIPLE) = past
           @(TRANS chase).

given    V* (^ PARTICIPLE) = past
           @(DITRANS give).

devoured    V* (^ PARTICIPLE) = past
           @(TRANS devour).

saw     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PAST
            @(OPT-TRANS see).

ate     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PAST
            @(OPT-TRANS eat).

slept     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PAST
            @(INTRANS sleep).

gave     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PAST
            @(DITRANS give).

waited     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PAST
            @(INTRANS wait).

talked     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PAST
            @(INTRANS talk).

sat     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PAST
            @(INTRANS sit).

argued     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PAST
            @(OPT-TRANS argue).

put  V* { @MOOD-IND
          @ASPECT-SIMP
          @PRES-NON3SG
          @(LOC-TRANS put)
        | @MOOD-IND
          @ASPECT-SIMP
          @PAST
          @(LOC-TRANS put)
        | (^ PARTICIPLE) = past
          @(LOC-TRANS put) }.



"ADJECTIVES"


small  A *  (^ PRED) = 'small'.

black  A *  (^ PRED) = 'black'.

hungry  A *  (^ PRED) = 'hungry'.



"ADVERBS"


quickly  Adv *  (^ PRED) = 'quickly'.

very  Adv *  (^ PRED) = 'very'.



"PRONOUNS - SUBJECT (without 2nd person & it)"


I   PRON * @(PRON-SUBJECT I sg 1).

he   PRON * @(PRON-SUBJECT he sg 3).

she   PRON * @(PRON-SUBJECT she sg 3).

we   PRON * @(PRON-SUBJECT we pl 1).

they   PRON * @(PRON-SUBJECT they pl 3).



"PRONOUNS - OBJECT (without 2nd person & it)"


me   PRON * @(PRON-OBJECT I sg 1).

him   PRON * @(PRON-OBJECT he sg 3).

"her   PRON * @(PRON-OBJECT she sg 3)."

us   PRON * @(PRON-OBJECT we pl 1).

them   PRON * @(PRON-OBJECT they pl 3).



"PRONOUNS - SUBJECT & OBJECT (2nd person & it)"


you  PRON * { @(PRON-SUBJECT you sg 2)
         | @(PRON-SUBJECT you pl 2)
         | @(PRON-OBJECT you sg 2)
         | @(PRON-OBJECT you pl 2) }.

it PRON * { @(PRON-SUBJECT it sg 3)
       | @(PRON-OBJECT it sg 3) }.



"PRONOUNS - POSSESIVE (they work are DETERMINERS)"

my    Pron * @(PRON-POSS I sg 1).

your  Pron * @(PRON-POSS you sg 2).

his   Pron * @(PRON-POSS he sg 3).

her   Pron * { @(PRON-OBJECT she sg 3)
             | @(PRON-POSS she sg 3)}.

our   Pron * @(PRON-POSS we pl 1).

their Pron * @(PRON-POSS they pl 3).



"PUNCTUATION"


,   COMMA * .

.   PERIOD * .

the  D *  (^ DEF) = +.

a   D *  (^ DEF) = -.

by P * { (^ PRED) = 'by<(^ OBJ)>'
          (^ PTYPE) = sem
          @(OT-MARK PPadj)
       | (^ PTYPE) = nosem
         (^ PFORM) = by }.

"by P * @(PREP by)."

to P * @(PREP to).

on P * @(PREP on).

in P * @(PREP in).

with P * @(PREP with).

for P * @(PREP for).

