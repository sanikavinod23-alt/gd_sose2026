DEMO   ENGLISH   CONFIG (1.0)
  ROOTCAT   ROOT.
  FILES  common.templates.lfg.
  LEXENTRIES   (DEMO ENGLISH)(MORPH ENGLISH).
  TEMPLATES (DEMO ENGLISH)(STANDARD COMMON). 
  RULES   (DEMO ENGLISH)(MORPH ENGLISH).
  MORPHOLOGY (DEMO ENGLISH).
  GOVERNABLERELATIONS    SUBJ OBJ OBJ2 COMP XCOMP OBL OBL-?+.
  SEMANTICFUNCTIONS    ADJUNCT  TOPIC FOCUS POSS STANDARD.
  NONDISTRIBUTIVES    NUM PERS CONJ-FORM.
  EPSILON   e.
  OPTIMALITYORDER NOGOOD PPadj +PPattach.
  GENOPTIMALITYORDER GenBadPunct NOGOOD +PUNCT CAPITAL.


----

DEMO ENGLISH MORPHOLOGY (1.0)

TOKENIZE:
P!basic-parse-tok.fst G!default-gen-tokenizer.fst

ANALYZE:
english.infl.patch.full.fst


----

DEMO   ENGLISH   RULES (1.0)

   ROOT --> { S
             (PERIOD: @(OT-MARK Punct))
              |
              Simp
             }.

   Simp --> e: (^ SUBJ PRED) = 'pro'
                (^ SUBJ PERS) = 2;
       VP: (^ TENSE) = pres;
       EXCLAMATION.   

   S --> NP: (^ SUBJ)=!
	     (! CASE)=nom;
 	 VP: ^=!;
      (PERIOD).

SCCOORD(CAT) = CAT: ! $ ^;
               CONJ
               CAT: ! $ ^.

NPCOORD(CAT) = CAT: ! $ ^;
               CONJ: ^ = !
                      (^ NUM) = pl;
               CAT: ! $ ^
                    @NP-CONJUNCT.

   VP --> (AUX: ^=!)
          V: ^=!; 
 	  (NP: (^ OBJ)=!
	       (! CASE)=acc)
       (NP: (^ OBJ2)=!)
       PP*: { ! $ (^ ADJUNCT) " $ -> this means -in the set of- "
                  (! PTYPE) =c sem
                  (! OBJ ANIM) =c +
                  @(OT-MARK PPadj) "We have marked the Adjunct. This means that if the noun of the PP is animate e.g. dog, girl, bird etc, the Adjunct will be penalized and xle will choose the unmarked type of PP, which will be the OBL."
             |
               ! $ (^ ADJUNCT)
                 (! PTYPE) =c sem
                 (! OBJ ANIM) =c -
            |
                (^ OBL) = !
                @(OT-MARK PPadj)}; "We have marked the OBL. This means that if the noun of the PP is inanimate e.g. chair, bench, bone etc, the OBL will be penalized and xle will choose the unmarked type of PP, which will be the Adjunct."
          (PP: (^ OBL-TO) = !)
          (PP: (^ OBL-AG) = !)
          { Adv*: ! $ (^ ADJUNCT)
          | @(SCCOORD VP)
          }.

   PP --> { P: ^ = !
               (! PTYPE) =c sem; "semantic type, ADJUNCT"
           NP: (^ OBJ) = !
               (! CASE) = acc
               |
           P: ^ = !
              (! PTYPE) =c nosem; "non-semantic type, OBL"
           NP
           | @(SCCOORD PP)
           }.


   NP --> { 
          ({D
          | PRON:
              (^ SPEC POSS) = !
              (^ SPEC POSS PRON-TYPE) =c poss})
           AP*: ! $ (^ ADJUNCT);
           N
           PP*: ! $ (^ ADJUNCT)
                    (! PTYPE) =c sem
                    @(OT-MARK PPadj)
           | PRON: ^=!
              (! PRON-TYPE) = pers
           | @(NPCOORD NP)
           }.


    AP --> AdvP*: ! $ (^ ADJUNCT);
           (COMMA)
           A.

    AdvP --> Adv*: ! $ (^ ADJUNCT);
           (COMMA)
           Adv.

    PRON --> Pron: ^=!
               {(! PRON-TYPE) = pers
               |(! PRON-TYPE) = poss}.


    METARULEMACRO(_CAT _BASECAT _RHS) =
         {
           _RHS
         |   "if it is an NP or an N, pass to NP coordination rule"
           e: _CAT $c { NP N };
           @(NPCOORD _CAT)
         |  "if it is any other category, pass it to
              the same category coordination rule"
           e: _CAT ~$ { NP N };
           @(SCCOORD _CAT)
         |  "allow bracketing around any category"
            LB: @(OT-MARK GenBadPunct); "preceding quote mark"
                                        "disprefer in generation"
            _CAT: @PUSHUP; "this pushes the quotes to the top
                            to avoid vacuous ambiguity"
            RB "following quote mark"}.

----

DEMO ENGLISH TEMPLATES (1.0)

OT-MARK(_mark) = "assigns an OT mark"
_mark $ o::*.

PRES3SG = (^ TENSE) = pres
          (^ SUBJ PERS) = 3
          (^ SUBJ NUM) = sg.

PRES-NON3SG = { (^ TENSE) = pres
                (^ SUBJ PERS) = 1
                (^ SUBJ NUM) = sg
              | (^ TENSE) = pres
                (^ SUBJ PERS) = 1
                (^ SUBJ NUM) = pl
              | (^ TENSE) = pres
                (^ SUBJ PERS) = 2
                (^ SUBJ NUM) = sg
              | (^ TENSE) = pres
                (^ SUBJ PERS) = 2
                (^ SUBJ NUM) = pl
              | (^ TENSE) = pres
                (^ SUBJ PERS) = 3
                (^ SUBJ NUM) = pl }.

PAST =  { (^ TENSE) = past
          (^ SUBJ PERS) = 1
          (^ SUBJ NUM) = sg
        | (^ TENSE) = past
          (^ SUBJ PERS) = 1
          (^ SUBJ NUM) = pl
        | (^ TENSE) = past
          (^ SUBJ PERS) = 2
          (^ SUBJ NUM) = sg
        | (^ TENSE) = past
          (^ SUBJ PERS) = 2
          (^ SUBJ NUM) = pl
        | (^ TENSE) = past
          (^ SUBJ PERS) = 3
          (^ SUBJ NUM) = sg
        | (^ TENSE) = past
          (^ SUBJ PERS) = 3
          (^ SUBJ NUM) = pl }.

PAST-BE-3SG = (^ TENSE) = past
          (^ SUBJ PERS) = 3
          (^ SUBJ NUM) = sg.

MOOD-IND = (^ MOOD) = indicative.

ASPECT-SIMP = (^ ASPECT) = simple.

SG-3PERS = (^ NUM) = sg
           (^ PERS) = 3.

PL-3PERS = (^ NUM) = pl
          (^ PERS) = 3.

CN = (^ DEF).

INTRANS(P) = (^ PRED)='P<(^ SUBJ)>'.

TRANS(P) = @(PASS (^ PRED)='P<(^ SUBJ)(^ OBJ)>').

OPT-TRANS(P) = { @(INTRANS P) | @(TRANS P) }.

PASS(FRAME) = { FRAME 
		(^ PASSIVE) = -
		| FRAME
		(^ PASSIVE) = +
		(^ PARTICIPLE) =c past
		(^ OBJ)-->(^ SUBJ)
		{ (^ SUBJ)-->(^ OBL-AG)
		| (^ SUBJ)--> NULL}
		}.

DAT-SHIFT(FRAME) = { FRAME
                     | FRAME
                       (^ OBJ)-->(^ OBJ2)
                       (^ OBL-TO)-->(^ OBJ)}.

DITRANS(P) = @(PASS @(DAT-SHIFT (^ PRED)='P<(^ SUBJ) (^ OBJ)
              (^ OBL-TO)>')).

LOC-TRANS(P) = @(PASS (^ PRED)='P<(^ SUBJ)(^ OBJ)(^ OBL)>')
               (^ OBL PTYPE) = nosem.

"LOC-TRANS(P) = @(PASS (^ PRED)='P<(^ SUBJ)(^ OBJ)(^ OBL)>')."

PREP(P) = { (^ PRED) = 'P<(^OBJ)>'
            (^ PTYPE) = sem
            | (^ PTYPE) = nosem
            (^ PFORM) = P}.

PRON-SUBJECT(P N C) = (^ PRED) = 'P'
              (^ NUM) = N
              (^ PERS) = C
              (^ CASE) = nom
              (^ PRON-TYPE) = pers
              (^ ANIM) = +.

PRON-OBJECT(P N C) = (^ PRED) = 'P'
              (^ NUM) = N
              (^ PERS) = C
              (^ CASE) = acc
              (^ PRON-TYPE) = pers
              (^ ANIM) = +.

PRON-POSS(P N C) = (^ DEF) = +
            (^ "SPEC POSS" PRED) = 'P'
            (^ "SPEC POSS" NUM) = N
            (^ "SPEC POSS" PERS) = C
            (^ "SPEC POSS" PRON-TYPE) = poss
            (^ "SPEC POSS" ANIM) = +.

NP-CONJUNCT = 
          {    
            (! PERS)=c 1
            (^ PERS)=1
          |    
            (! PERS)=c 2
          { (^ PERS)=c 1 
          | (^ PERS)=2 } 
          | (^ PERS)=3
          }.

