       ETC.

build  V-S XLE @(TRANS build);
       ETC.

house  +V-S XLE @(TRANS house);
       ETC.

give     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PRES-NON3SG
            @(DITRANS give).

gives   V * 
	       @MOOD-IND
            @ASPECT-SIMP
            @PRES3SG
	       @(DITRANS give).

was   AUX * "(^ PRED) = 'be'"
            @MOOD-IND
            @PAST-BE-3SG
            (^ PARTICIPLE) =c past.

seen    V* (^ PARTICIPLE) = past
           @(TRANS see).

eaten    V* (^ PARTICIPLE) = past
           @(TRANS eat).

chased    V* (^ PARTICIPLE) = past
           @(TRANS chase).

given    V* (^ PARTICIPLE) = past
           @(DITRANS give).

built  V* (^ PARTICIPLE) = past
          @(TRANS build).

devoured    V* (^ PARTICIPLE) = past
           @(TRANS devour).

saw     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PAST
            @(OPT-TRANS see).

ate     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PAST
            @(OPT-TRANS eat).

slept     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PAST
            @(INTRANS sleep).

gave     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PAST
            @(DITRANS give).

waited     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PAST
            @(INTRANS wait).

talked     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PAST
            @(INTRANS talk).

sat     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PAST
            @(INTRANS sit).

argued     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PAST
            @(OPT-TRANS argue).

