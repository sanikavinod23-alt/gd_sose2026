"VERBS"


devours   V * 
	       @MOOD-IND
            @ASPECT-SIMP
            @PRES3SG
	       @(TRANS devour).

like   V * 
	       @MOOD-IND
            @ASPECT-SIMP
            @PRES-NON3SG
	       @(TRANS like).

devour     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PRES-NON3SG
            @(TRANS devour).

appears   V * 
	       @MOOD-IND
            @ASPECT-SIMP
            @PRES3SG
	       @(INTRANS appear).

wait     V*
            @MOOD-IND
            @ASPECT-SIMP
            @PRES-NON3SG
            @(INTRANS wait).

waits    V *
	       @MOOD-IND
            @ASPECT-SIMP
            @PRES3SG
	       @(INTRANS wait).

