											@(OT-MARK AnimObl)} 
											(^ OBL PFORM) =c with
						 }
						@VPRES
						@SG-AGR.

	argue 		V 	*  	{@(INTRANS argue) | @(INTRANS-OBL argue) 
											{(^ OBL ANIMATE) =c +
											@(OT-MARK AnimObl)} 
											(^ OBL PFORM) =c with
						 }
						@VPRES
						@BARE-AGR.

	argued 		V 	*  	{@(INTRANS argue) | @(INTRANS-OBL argue) 
											{(^ OBL ANIMATE) =c +
											@(OT-MARK AnimObl)} 
											(^ OBL PFORM) =c with
						 }
						@VPAST.
	
	Think		V 	*	@(TRANS think)
						@VPRES
						@BARE-AGR.

	educate		V 	*	@(TRANS educate)
						@VPRES
						@BARE-AGR.

	educates	V	*	@(TRANS educate)
						@VPRES
						@SG-AGR.

	educated	V	*	@(TRANS educate)
