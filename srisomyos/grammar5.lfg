	likes		V 	*	@(TRANS like)
						@VPRES
						@SG-AGR.
	
	like		V 	*	@(TRANS like)
						@VPRES
						@BARE-AGR.

	liked		V	*	@(TRANS like)
						{ @PASTP | @VPAST }.

"Auxiliary"

	is		AUX		*	@(TENSE pres)
						(^ SUBJ PERS) = 3
						(^ SUBJ NUM) = sg
						@BE.

	am		AUX		*	@(TENSE pres)
						(^ SUBJ PERS) = 1
						(^ SUBJ NUM) = sg
						@BE.
	
	are		AUX		*	@(TENSE pres)
						{ (^ SUBJ PERS) = 2 | (^ SUBJ PERS) = 3 }
						(^ SUBJ NUM) = pl
						@BE.

	was		AUX		*	@(TENSE past)
						{ (^ SUBJ PERS) = 1 | (^ SUBJ PERS) = 3 }
						(^ SUBJ NUM) = sg
						@BE.

	were	AUX		*	@(TENSE past)
						{ (^ SUBJ PERS) = 2 | (^ SUBJ PERS) = 3 }
						(^ SUBJ NUM) = pl
						@BE.

"Adjective"

	small		A 		* 	@(PRED small).
	black		A 		* 	@(PRED black).
	hungry		A 		* 	@(PRED hungry).
	creative	A 		* 	@(PRED creative).
	bright		A 		* 	@(PRED bright).
	intelligent	A 		* 	@(PRED intelligent).
	efficient	A 		* 	@(PRED efficient).
	lazy		A 		* 	@(PRED lazy).

"Adverb"

	quickly	ADV 	* 	@(PRED quickly). 
	very   	ADV 	* 	@(PRED very). 


"Preposition"

	by 		P 	* 	@(PREP by).
	to 		P 	*	@(PREP to).
	on 		P 	* 	@(PREP on).
	in 		P 	* 	@(PREP in).
	with 	P 	* 	@(PREP with).
	for 	P 	* 	@(PREP for).

"Determiner"

	the		D	* 	(^ DEF) = +.

	The		D	* 	(^ DEF) = +.

	a   	D	* 	(^ DEF) = -
					(^ NUM) = sg.


	"Possessive determiner"

	my		D	*	@(POSSDET my 1 sg).

	your	D	*	{@(POSSDET your 2 sg)
					|@(POSSDET your 2 pl)}.

	"his		D	*	@(POSSDET his 3 sg)."

	her		D	*	@(POSSDET her 3 sg).

	their	D	*	@(POSSDET their 3 pl).

	our		D	*	@(POSSDET our 1 pl).

	its		D	*	@(POSSDET its 3 sg).

"Coordination"

	and  CONJ 	* 	@(COORD-FORM %stem);
		 CONJnp * @(COORD-FORM %stem) @(NUM pl).


"Punctuation"

	. PERIOD * (^ STMT-TYPE) = decl. 

	, COMMA  * . 

	!  EXCL * (^ STMT-TYPE) = excl. 


