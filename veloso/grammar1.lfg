DEMO   ENGLISH   CONFIG (1.0)
  ROOTCAT   S.
  FILES  .
  LEXENTRIES   (DEMO ENGLISH).
  TEMPLATES (DEMO ENGLISH). 
  RULES   (DEMO ENGLISH).
  GOVERNABLERELATIONS    SUBJ OBJ OBJ2 COMP XCOMP OBL OBL-?+.
  SEMANTICFUNCTIONS    ADJUNCT  TOPIC FOCUS POSS STANDARD.
  NONDISTRIBUTIVES    NUM PERS CONJ-FORM.
  EPSILON   e.
  EPSILON   e.
  OPTIMALITYORDER NOGOOD  PPadj +PPattach.
  GENOPTIMALITYORDER NOGOOD .

----

DEMO   ENGLISH   RULES (1.0)

   S --> NP: (^ SUBJ)=!
	     (! CASE)=nom;
 	 VP: ^=!.

   VP --> (AUX)                  	"auxiliary introduced for passive" 
          V: ^=!; 
          (NP: (^ OBJ)=!         	"optional direct object"
               (! CASE)=acc)
          (NP: (^ OBJ2)=!)       	"restricted obj of di-transitives"
           
          PP*: { ! $ (^ ADJUNCT) 	"PPs can be adjuncts"
                     (! PTYPE) =c sem 	"only semantic PPs here"
                     @(OT-MARK PPadj)   "disprefer adjunct PP"
                       | 
                      (^ OBL) = ! 	"or a a general oblique"
                        };
          (PP: (^ OBL-TO) = !)   	"oblique beneficiary of di-trn"
          (PP: (^ OBL-AG) = !)  	"oblique agent of passive"
          Adv*: ! $ (^ ADJUNCT).

   NP --> {(D)	 			"optional determiner, can leave out ^=!"
           AP*: ! $ (^ ADJUNCT);	"introducing adjectives in sets"	
 	   N				"head NP"
           PP*: ! $ (^ ADJUNCT)		"PPs modifying NPs"
                   (! PTYPE) =c sem	"have to be semantic"
                  @(OT-MARK PPattach)	"prefer PPs attached to NPs"
          |PRON}.

   AP --> Adv*: ! $ (^ ADJUNCT);
          A.

   PP --> { P: ^ = !			"head of PP"
                (! PTYPE) =c sem;	"semantic type, Adjunct"
            NP: (^ OBJ) = !		
                (! CASE) = acc;
          | P: ^ = !			"head of PP"
                (! PTYPE) =c nosem;	"non-semantic type, OBL"
                NP }.

----

DEMO ENGLISH TEMPLATES (1.0)

"count noun singular"
CNS(P) = (^ PRED) ='P' 
         (^ NUM) = sg
         (^ DEF).

"count noun plural"
CNP(P) = (^ PRED)='P' 
         (^ NUM)= pl.

"proper noun"
PN(P) = (^ PRED) ='P' 
        (^ NUM) = sg
        (^ PERS) = 3
      ~[(^ DEF)].

"present 3rd person singular"
PRES3SG = (^ TENSE) = pres
          (^ ASPECT) = simple
          (^ MOOD) = ind
          (^ SUBJ PERS) = 3 
          (^ SUBJ NUM) = sg.

"present"
PRES = (^ TENSE) = pres
       (^ ASPECT) = simple
       (^ MOOD) = ind
      {(^ SUBJ PERS) = 1
      |(^ SUBJ PERS) = 2}
      {(^ SUBJ NUM) = sg
      |(^ SUBJ NUM) = pl}
      {(^ SUBJ PERS) = 3
       (^ SUBJ NUM) = pl}.

"past all persons"
PAST = (^ TENSE) = past
          (^ ASPECT) = simple
          (^ MOOD) = ind
         {(^ SUBJ PERS) = 1
         |(^ SUBJ PERS) = 2
         |(^ SUBJ PERS) = 3}
         {(^ SUBJ NUM) = sg
         |(^ SUBJ NUM) = pl}.

"intransitive verbs"
INTRANS(P) = (^ PRED)='P<(^ SUBJ)>'.

"transitive verbs"
TRANS(P) = @(PASS (^ PRED)='P<(^ SUBJ)(^ OBJ)>'). 

"optionally transitive verbs"
OPTTRANS(P) = { @(INTRANS P) | @(TRANS P) }. 

DITRANS(P) = @(PASS @(DAT-SHIFT (^ PRED)='P<(^ SUBJ) (^ OBJ)
              (^ OBL-TO)>')).

"passive"
PASS(FRAME) = { FRAME 				"no passive, just give back subcat frame"
                 (^ PASSIVE) = - 		"no passive"
               | FRAME 				"passive"
                 (^ PASSIVE) = + 		"mark as such"
                 (^ PARTICIPLE) =c past 	"make sure to have a past participle"
                 (^ OBJ) --> (^ SUBJ) 		"obj goes to subj; only (at least) transitives"
                 { (^ SUBJ) --> (^ OBL-AG) 	"either make subj obl-ag"
                 | (^ SUBJ) --> NULL 		"or delete"
                 }
               }.

PASTP = (^ PARTICIPLE) = past.

DAT-SHIFT(FRAME) = { FRAME 
                    | FRAME 
                      (^ OBJ)-->(^ OBJ2)
                      (^ OBL-TO)-->(^ OBJ)}.

"template for most prepositions"
PREP(P) = { (^ PRED) = 'P<(^OBJ)>' 
            (^ PTYPE) = sem
          | (^ PTYPE) = nosem
            (^ PFORM) = P}.

"assigns an OT mark"
OT-MARK(_mark) = _mark $ o::*.

