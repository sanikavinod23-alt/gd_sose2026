DEMO ENGLISH LEXICON (1.0)

"Verbs"

"Morphologically analyzed"

yawn      V-S XLE @(INTRANS %stem).

build	  V-S XLE @(TRANS %stem). 

hate	  V-S XLE @(TRANS %stem).  "using the morphological analyzer"

house     V-S XLE @(TRANS %stem); ETC.

implement     V-S XLE @(TRANS %stem).

love    V-S XLE @(TRANS %stem); ETC.

steal  V-S XLE @(TRANS %stem).

dedicate  V-S XLE @(DITRANS-OBL %stem).

eat       V-S XLE @(OPT-TRANS %stem); ETC. 

"Fullforms"

appears   V *  (^ PRED) = 'appear<(^SUBJ)>'
       	    @PRES3SG.

sleep   V *  @(INTRANS sleep)
       	    @BARE-AGR
	    @PRES.

sleeps V * @(INTRANS sleep) @PRES3SG.

slept V * @(INTRANS sleep) @PAST.

devours   V *  @(TRANS devour)
       	    @PRES3SG.

devour   V *  @(TRANS devour)
       	    @BARE-AGR
	    @PRES.

devoured   V *  @(TRANS devour)
       	    @PAST-BOTH.

chases  V *  @(TRANS chase)
       	    @PRES3SG.

chase  V *  @(TRANS chase)
       	    @BARE-AGR
	    @PRES.

chased  V *  @(TRANS chase)
       	     @PAST-BOTH.

educated  V *  @(TRANS educate)
       	     @PAST-BOTH.

like  V *  @(TRANS like)
       	    @BARE-AGR
	    @PRES.

Think  V *  @(TRANS think)
       	    @BARE-AGR
	    @PRES.

Eats    V * @(OPT-TRANS eat)
            @PRES3SG.

eats    V * @(OPT-TRANS eat)
            @PRES3SG.

Eat    V * @(OPT-TRANS eat)
           @BARE-AGR
	   @PRES.

eat    V * @(OPT-TRANS eat)
           @BARE-AGR
	   @PRES.
	   
ate    V * @(OPT-TRANS eat)
	   @PAST.

eaten V * @(OPT-TRANS eat)
          @PASTP.

"Obliques"

argued V *   { @(INTRANS argue) |
              @(INTRANS-OBL argue)
	      {(^ OBL ANIMATE) =c +
	        @(OT-MARK AnimObl)}
	       (^ OBL PFORM) =c with}
	       @PAST.

talked V *  { @(INTRANS talk) |
              @(INTRANS-OBL talk)
	      {(^ OBL ANIMATE) =c +
	        @(OT-MARK AnimObl)}
	      {(^ OBL PFORM) =c with|
	       (^ OBL PFORM) =c to}}
	       @PAST.

waited V *  { @(INTRANS wait) |
              @(INTRANS-OBL wait)
	      {(^ OBL ANIMATE) =c +
	        @(OT-MARK AnimObl)}	
	      (^ OBL PFORM) =c on}
	      @PAST.

sat V *    @(INTRANS-OBL wait)
	   (^ OBL PFORM) =c on
	   @PAST.

saw V * @(TRANS see)
        @PAST.

see    V * @(TRANS see)
           @BARE-AGR
	   @PRES.

seen V *   @(TRANS see)
           @PASTP.

Gave 	  V * @(DITRANS give)
	      @PAST. 

gave 	  V * @(DITRANS give)
	      @PAST.
	     

gives     V * @(DITRANS give)
	      @PRES3SG.

give      V * @(DITRANS give)
	      @BARE-AGR
	      @PRES.

Give      V * @(DITRANS give)
	      @BARE-AGR
	      @PRES.

given 	  V * @(DITRANS give)
	       @PASTP.

put 	  V * @(DITRANS-OBL give)
	       @PAST-BOTH.

"auxiliaries"

was 	  AUX * @PAST
                (^ PASSIVE) =c +
		{ (^ SUBJ PERS) = 1
                | (^ SUBJ PERS) = 3
                }
                (^ SUBJ NUM) = sg.

"adjectives"

bright  A * @(PRED bright).

creative  A * @(PRED creative).

efficient  A * @(PRED efficient).

intelligent	A * @(PRED intelligent).

lazy  A * @(PRED lazy).

small	A * @(PRED small). 

