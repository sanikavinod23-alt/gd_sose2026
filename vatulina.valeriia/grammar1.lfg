DEMO   ENGLISH   CONFIG (1.0)
  ROOTCAT   ROOT.
  FILES  common.templates.lfg .
  LEXENTRIES   (DEMO ENGLISH).
  TEMPLATES (DEMO ENGLISH) (STANDARD COMMON). 
  RULES   (DEMO ENGLISH).
  GOVERNABLERELATIONS    SUBJ OBJ OBJ2 COMP XCOMP OBL OBL-?+.
  SEMANTICFUNCTIONS    ADJUNCT  TOPIC FOCUS POSS STANDARD.
  NONDISTRIBUTIVES    NUM PERS CONJ-FORM COORD-FORM.
  EPSILON   e.
  OPTIMALITYORDER NOGOOD  PPadj +OblAg +PPattach +sg-imp.
  GENOPTIMALITYORDER NOGOOD GenBadPunct.

----

DEMO ENGLISH MORPHOLOGY (1.0)

TOKENIZE:
P!basic-parse-tok.fst G!default-gen-tokenizer.fst

----

DEMO   ENGLISH   RULES (1.0)
	ROOT -->	{S | Simp}.

	Simp --> e: (^ SUBJ PRED) = 'pro'
		        (^ SUBJ PERS) = 2;
		     VP: ^ = !
			 	(^ TENSE) ~= past;
		     EXCL.

   	S -->	NP: (^ SUBJ) = !
	    	    	(! CASE) = nom;
 	             VP: ^=!;
		     (PERIOD).

   	VP -->	(AUX)
			V:^=!;
			(NP: (^ OBJ) = ! "optional direct object"
	    		 (! CASE) = acc)
			Adv*: ! $ (^ ADJUNCT);
			(NP: (^ OBJ2) = !) "restricted object of d-transitives"
			PP*: { ! $	(^ ADJUNCT) "PPs can be adjuncts"
						(! PTYPE) =c sem 
						@(OT-MARK PPadj)
						|
						(^ OBL) = !
						(! PTYPE) =c nosem "or a a general oblique"
						};
			(PP: (^ OBL-TO) = !
				 (! PFORM) =c to)
			(PP: (^ OBL-AG) = !
				 (! PFORM) =c by
				 @(OT-MARK OblAg)).

   	NP -->	{({D
			|
			PRON: (! PRON-TYPE) =c poss
				  (^ POSS) = !;
			})
   			AP*: ! $ (^ ADJUNCT);
 			N
			PP*: ! $ (^ ADJUNCT)
				 (! PTYPE) =c sem 
				 @(OT-MARK PPattach)
			|
			PRON
			}.

	AP -->	Adv*: ! $ (^ ADJUNCT);
			A
			(COMMA).

   	PP -->	{P: ^=!
   				(! PTYPE) =c sem;
			NP: (^ OBJ) = !
			    (! CASE) = acc;
			|
			P: ^=!
			    (! PTYPE) =c nosem;
			NP
			}.

	SCCOORD(_CAT) =	
					_CAT:	@IN-SET;
					(COMMA: @(OT-MARK GenBadPunct))
					CONJ:	@PUSHUP;
					_CAT:	@IN-SET.
	
	NPCOORD(_CAT) =	
					_CAT:	@IN-SET
							@NP-CONJUNCT;
					CONJnp:	@PUSHUP;
					_CAT:	@IN-SET
							@NP-CONJUNCT.
	
	METARULEMACRO(_CAT _BASECAT _RHS)=

    {	
		_RHS
    |	
		e: _CAT $c { NP N };
      	@(NPCOORD _CAT)
	|
    	e: _CAT ~$ { NP N };
      	@(SCCOORD _CAT)

    |
		LB: @(OT-MARK GenBadPunct);
      	_CAT: @PUSHUP;
      	RB
	}.
----

DEMO ENGLISH TEMPLATES (1.0)

OT-MARK(_mark) = "assigns an OT mark, from common templates"
    _mark $ o::*.

"verbs"

TRANS(P) = @(PASS (^ PRED) = 'P<(^ SUBJ) (^ OBJ)>').

INTRANS(P) = (^ PRED) = 'P<(^ SUBJ)>'
	     (^ PASSIVE) = -.

OPT-TRANS(P) = { @(INTRANS P) | @(TRANS P) }.

DI-TRANS(P) = @(PASS @(DAT-SHIFT (^ PRED) = 'P<(^ SUBJ) (^ OBJ) (^ OBL-TO)>')).

INTRANS-OBL(P) = @(PASS (^ PRED) = 'P<(^ SUBJ)(^ OBL)>')
		(^ OBL PTYPE) = nosem.

TRANS-OBL(P) = @(PASS(^ PRED) = 'P<(^ SUBJ) (^ OBJ) (^ OBL)>').

IND-MD = (^ MOOD) = indicative.

PRES-TNS = (^ TENSE) = pres.

PAST-TNS = (^ TENSE) = past.

PAST-PRT = (^ PARTICIPLE) = past
		   (^ PASSIVE) = +.

"nouns"

PROPER-NOUN-NAME(P N H T Y S) = (^ PRED) = 'P'
				 (^ NUM) = N
				 (^ PERS) = 3
				 (^ HUMAN) = H
				 (^ NTYPE NSEM PROPER NAME-TYPE) = T
				 (^ NTYPE NSEM PROPER PROPER-TYPE) = name
				 (^ NTYPE NSYN) = proper
				 (^ GEND-SEM) = S.

ANIMATE = (^ ANIMATE) = +.

INANIMATE = (^ ANIMATE) = -.

3PER-SG =	(^ SUBJ PERS) = 3
	    	(^ SUBJ NUM) = sg.

OTH-PER =	{ (^ SUBJ NUM) = pl
	  		| 
			  (^ SUBJ PERS) ~= 3
			  (^ SUBJ NUM) = sg
			  @(OT-MARK sg-imp)
	  		}.

CN-SG = (^ NUM) = sg
		(^ PERS) = 3
		{ (^ DEF)
        | (^ POSS)
        }.

CN-PL = (^ NUM) = pl
		(^ PERS) = 3.

NP-CONJUNCT =
	{
		(! PERS)=c 1
		(^ PERS)=1
	|
		(! PERS)=c 2
		{
			(^ PERS)=c 1
		|
			(^ PERS)=2
		}
	|
		(^ PERS)=3
	}.

PRON-PERS(P N S) = (^ PRED) = 'P'
			   (^ NUM) = N
			   (^ PERS) = S
			   (^ PRON-TYPE) = personal.

PRON-CASE(C) = (^ CASE) = C.

PRON-POSS(P R) = (^ PRED) = 'P'
		 (^ PERS) = R
	         (^ PRON-TYPE) = poss.

PREP(P) = {(^ PTYPE) = sem
	   (^ PRED) = 'P<(^ OBJ)>'
	   | 	
	   (^ PTYPE) = nosem
	   (^ PFORM) = P
	  }.

DAT-SHIFT (FRAME) = {FRAME
		    | FRAME
		    (^ OBJ) --> (^OBJ2)
		    (^ OBL-TO) --> (^OBJ)}.

PASS (FRAME) = { FRAME
		   (^ PASSIVE) = -
		   | FRAME "passive"
		   (^ PASSIVE) = +
		   (^ PARTICIPLE) =c past "only past participle allowed"
		   (^ OBJ) --> (^ SUBJ)
		   { (^ SUBJ) --> (^ OBL-AG)
		   | (^ SUBJ) --> NULL
		   }
		}.
----

DEMO ENGLISH LEXICON (1.0)

"adjectives"

black		A * (^ PRED) = 'black'.

bright		A * (^ PRED) = 'bright'.

creative	A * (^ PRED) = 'creative'.

efficient	A * (^ PRED) = 'efficient'.

