"verbs"

argued		V * @(INTRANS-OBL argue)
		    	(^ OBL PFORM) =c with
		    	@PAST-TNS.

chase		V * @(TRANS chase)
	    	    @PRES-TNS
	    	    @OTH-PER.

chases		V * @(TRANS chase)
	    	    @PRES-TNS
	     	    @3PER-SG.

chased		V * @(TRANS chase)
	    	    { @PAST-PRT
	    	    |
		    	@PAST-TNS}.

devour		V * @(TRANS devour)
	    	    @PRES-TNS
	    	    @OTH-PER.

devoured	V * @(TRANS devour)
	    	    { @PAST-PRT
	    	    |
		    	@PAST-TNS}.

devours		V * @(TRANS devour)
	    	    @PRES-TNS
	    	    @3PER-SG.

eats		V * @(OPT-TRANS eat)
	    	    @PRES-TNS
	    	    @3PER-SG.

eat			V * @(OPT-TRANS eat)
	    	    @PRES-TNS
	    	    @OTH-PER.

ate			V * @(OPT-TRANS eat)
	    	    @PAST-TNS.

eaten		V * @(OPT-TRANS eat)
		    	@PAST-PRT.

educate 	V * @(TRANS educate)
	    	    @PRES-TNS
	    	    @OTH-PER.

educates 	V * @(TRANS educate)
	    	    @PRES-TNS
	    	    @3PER-SG.

educated	V * @(TRANS educate)
				{ @PAST-PRT
	    	    |
		    	@PAST-TNS}.

give		V * @(DI-TRANS give)
		   		@PRES-TNS
		    	@OTH-PER.

gives		V * @(DI-TRANS give)
		    	@PRES-TNS
		    	@3PER-SG.

given		V * @(DI-TRANS give)
		    	@PAST-PRT.

gave		V * @(DI-TRANS give)
		    	@PAST-TNS.

like 		V * @(TRANS like)
	    	    @PRES-TNS
	    	    @OTH-PER.

likes		V * @(TRANS like)
	    	    @PRES-TNS
	    	    @3PER-SG.

liked		V * @(TRANS like)
				{ @PAST-PRT
	    	    |
		    	@PAST-TNS}.

put 		V *@(TRANS-OBL put)
				{(^ OBL PFORM) =c in
				|
				(^ OBL PFORM) =c on}
		    	{ @PAST-PRT
	    	    |
		    	@PAST-TNS}.

see			V * @(TRANS see)
	    	    @PRES-TNS
	    	    @OTH-PER.

sees		V * @(TRANS see)
	    	    @PRES-TNS
	    	    @3PER-SG.

saw			V * @(TRANS see)
		    	@PAST-TNS.

seen		V * @(TRANS see)
	    	    @PAST-PRT.

sit 		V * @(INTRANS sit)
		    	@PRES-TNS
		    	@OTH-PER.

sat			V * @(INTRANS sit)
		    	@PAST-TNS.

sleep		V * @(INTRANS sleep)
	    	    @PRES-TNS
	    	    @OTH-PER.

sleeps		V * @(INTRANS sleep)
		    	@PRES-TNS
	    	    @3PER-SG.

slept		V * @(INTRANS sleep)
		    	@PAST-TNS.

talked		V * {@(INTRANS talk) 
		    	| 
		    	@(INTRANS-OBL talk)
		    	(^ OBL PFORM) =c to}
		    	@PAST-TNS.

think 		V * @(TRANS think)
	    	    @PRES-TNS
	    	    @OTH-PER.

waited		V * {@(INTRANS wait)
				|
				@(INTRANS-OBL wait)
				{
		    	(^ OBL PFORM) =c on
				(^ OBL ANIMATE) =c +
				|
				(^ OBL PFORM) =c for
				(^ OBL ANIMATE) =c +}
				}
		    	@PAST-TNS.

"determiners"

the		D *	(^ DEF) = +.

a		D *	(^ DEF) = -
			(^ NUM) = sg.

"pronouns"

I		PRON * @(PRON-PERS I sg 1)
			   @(PRON-CASE nom).

me		PRON * @(PRON-PERS I sg 1)
			   @(PRON-CASE acc).

my		PRON * @(PRON-POSS I 1).

we		PRON * @(PRON-PERS we pl 1)
			   @(PRON-CASE nom).

us		PRON * @(PRON-PERS we pl 1)
			   @(PRON-CASE acc).

you		PRON * {@(PRON-PERS you sg 2)
				|
				@(PRON-PERS you pl 2)
				}.

he 		PRON * @(PRON-PERS he sg 3)
			   @(PRON-CASE nom)
			   @ANIMATE.

him 	PRON * @(PRON-PERS he sg 3)
			   @(PRON-CASE acc)
			   @ANIMATE.

his 	PRON * @(PRON-POSS he 3).

she		PRON * @(PRON-PERS she sg 3)
			   @(PRON-CASE nom).

her		PRON * {@(PRON-PERS she sg 3)
				@(PRON-CASE acc)
				|
				@(PRON-POSS she 3)
				}.

				"PRON *(...) два різних записи"
				"POSS * (...)"

it 		PRON * {@(PRON-PERS it sg 3)
			   @(PRON-CASE nom)
				|
				@(PRON-PERS it sg 3)
				@(PRON-CASE acc)
				}.

its 	PRON * @(PRON-POSS it 3).

they	PRON * @(PRON-PERS they pl 3)
			   @(PRON-CASE nom).

them	PRON * @(PRON-PERS they pl 3)
			   @(PRON-CASE acc).

"prepositions"

by 		P *@(PREP by).

to 		P *@(PREP to).

in 		P *@(PREP in).

with 	P *@(PREP with).

on 		P *@(PREP on).

for 	P *@(PREP for).

"auxiliaries"

was		AUX * 	@PAST-TNS
				(^ PASSIVE) = +
	      		{ (^ SUBJ PERS) = 1
	      		| (^ SUBJ PERS) = 3
	      		}
	      		(^ SUBJ NUM) = sg.

were	AUX * 	@PAST-TNS
				(^ PASSIVE) = +
	      		{ (^ SUBJ PERS) = 2
	      		| (^ SUBJ PERS) = 3c
	      		}
	      		(^ SUBJ NUM) = pl.

"conjunctions"

and CONJ * @(COORD-FORM %stem);
	CONJnp * @(COORD-FORM %stem) @(NUM pl).
	

"punctuation"

.	PERIOD * .

,	COMMA * .

!	EXCL * .

