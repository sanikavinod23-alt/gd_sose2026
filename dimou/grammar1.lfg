DEMO ENGLISH LEXICON (1.0)

"Verbs"

hate	  V-S XLE @(TRANS %stem).  E @(OPT-TRANS %stem); ETC. 

implement V-S XLE @(TRANS %stem).

yawn     V-S XLE @(INTRANS %stem).

rain     V-S XLE @(INTRANS %stem).

steal    V-S XLE @(TRANS %stem).

house 	  V-S XLE @(TRANS house); ETC.

build     V-S XLE @(TRANS %stem).

think     V-S XLE (^PRED) = '%stem<(^SUBJ)(^COMP)>'.

convince  V-S XLE (^PRED) = '%stem<(^SUBJ)(^OBJ)(^XCOMP)>'
                            (^ XCOMP SUBJ) = (^OBJ).

persuade V-S XLE (^PRED) = '%stem<(^SUBJ)(^OBJ)(^XCOMP)>'
                            (^ XCOMP SUBJ) = (^OBJ).

promise V-S XLE (^PRED) = '%stem<(^SUBJ)(^OBJ)(^XCOMP)>'
                            (^ XCOMP SUBJ) = (^SUBJ).

say     V-S XLE { (^ PRED) ='say<(^ SUBJ)(^ COMP)>'
	        |(^ PRED) = 'say<(^ SUBJ)(^ OBJ)>'}.

try 	  V-S XLE (^ PRED) ='try<(^ SUBJ)(^ XCOMP)>'
	         (^ SUBJ) = (^ XCOMP SUBJ).

want   V-S XLE { (^ PRED) ='want<(^ SUBJ)(^OBJ)(^XCOMP)>'
                            (^ XCOMP SUBJ) = (^OBJ)
                |
	         (^ PRED) ='want<(^ SUBJ)(^ XCOMP)>'
	         (^ SUBJ) = (^ XCOMP SUBJ)}.

seem   V-S XLE (^ PRED) = 'seem<(^XCOMP)>(^SUBJ)'
               (^ XCOMP SUBJ) = (^ SUBJ).


"full-form entries"

appears   V *  (^ PRED) = 'appear<(^SUBJ)>'
       	                 @PRES3SG.

sleep   V *  @(INTRANS sleep)
       	    @BARE-AGR
	    @PRES.


sleeps V * @(INTRANS sleep) 
           @PRES3SG.

slept V * @(INTRANS sleep) 
          @PAST.

devours   V *  @(TRANS devour)
       	    @PRES3SG.

devour   V *  @(TRANS devour)
       	    @BARE-AGR
	    @PRES.

devoured   V *  @(TRANS devour)
       	    @PAST-BOTH.

chases  V *  @(TRANS devour)
       	    @PRES3SG.

chase  V *  @(TRANS devour)
       	    @BARE-AGR
	    @PRES.

chased  V *  @(TRANS devour)
       	     @PAST-BOTH.

eats    V * @(OPT-TRANS eat)
            @PRES3SG.

eat    V * @(OPT-TRANS eat)
           @BARE-AGR
	   @PRES.

Eat    V * @(OPT-TRANS eat)
           @BARE-AGR
	   @PRES.

ate    V * @(OPT-TRANS eat)
	   @PAST.

eaten V * @(OPT-TRANS eat)
          @PASTP.

educate V * @(TRANS educate)
           @BARE-AGR
	   @PRES.

educates  V * @(TRANS educate)
            @PRES3SG.

educated  V * @(TRANS educate)
             @PAST-BOTH.

like   V * @(TRANS like)
           @BARE-AGR
	   @PRES.

likes  V * @(TRANS like)
            @PRES3SG.

liked  V * @(TRANS like)
             @PAST-BOTH.


"think V * @(OPT-TRANS think)
           @BARE-AGR
	   @PRES.

Think  V * @(OPT-TRANS think)
           @BARE-AGR
	   @PRES.

thinks  V * @(OPT-TRANS think)
            @PRES3SG.

thought  V * @(OPT-TRANS think)
             @PAST-BOTH."


"Obliques"

argued V *   { @(INTRANS argue) |
              @(INTRANS-OBL argue)
	      {(^ OBL ANIMATE) =c +
	        @(OT-MARK AnimObl)}
	       (^ OBL PFORM) =c with}
	       @PAST.

talked V *  { @(INTRANS talk) |
              @(INTRANS-OBL talk)
	      {(^ OBL ANIMATE) =c +
	        @(OT-MARK AnimObl)}
	      {(^ OBL PFORM) =c with|
	       (^ OBL PFORM) =c to}}
	       @PAST.

waited V *  { @(INTRANS wait) |
              @(INTRANS-OBL wait)
	      {(^ OBL ANIMATE) =c +
	        @(OT-MARK AnimObl)}	
	      (^ OBL PFORM) =c on}
	      @PAST.

sat V *    @(INTRANS-OBL wait)
	   (^ OBL PFORM) =c on
	   @PAST.

saw V * @(TRANS see)
        @PAST.

see    V * @(TRANS see)
           @BARE-AGR
	   @PRES.

seen V *   @(TRANS see)
           @PASTP.



gave 	  V * @(DITRANS give)
	      @PAST. 

gives     V * @(DITRANS give)
	      @PRES3SG.

give      V * @(DITRANS give)
	      @BARE-AGR
	      @PRES.

Give      V * @(DITRANS give)
	      @BARE-AGR
	      @PRES.

given 	  V * @(DITRANS give)
	       @PASTP.

put 	  V * @(DITRANS-OBL give)
	       @PAST-BOTH.

"auxiliaries"

was 	  AUX * @PAST
                (^ PASSIVE) =c +
		{ (^ SUBJ PERS) = 1
                | (^ SUBJ PERS) = 3
                }
                (^ SUBJ NUM) = sg.

were     AUX * @PAST
                (^ PASSIVE) =c +
                (^ SUBJ NUM) = pl.


is      AUX * .

are     AUX * .

be     AUX * .


"adjectives"

"small	A * @(PRED small). 

